{% doc %}
  Product Information Content

  Renders the product information layout with media gallery and product details.
  Used by both product-information and featured-product-information sections.

  @param {number} product_media_size - Number of media items in the product
  @param {string} section_id - Unique section ID
  @param {object} settings - Section settings object
  @param {string} media_gallery - Captured HTML for the product media gallery block
  @param {string} product_details - Captured HTML for the product details block
  @param {string} additional_blocks - Captured HTML for additional section blocks

  @example
  {% capture media_gallery %}
    {% content_for 'block', type: '_product-media-gallery', id: 'media-gallery', closest.product: product %}
  {% endcapture %}

  {% capture product_details %}
    {% content_for 'block', type: '_product-details', id: 'product-details', closest.product: product %}
  {% endcapture %}

  {% capture additional_blocks %}
    {% content_for 'blocks' %}
  {% endcapture %}

  {% render 'product-information-content',
    product_media_size: product.media.size,
    section_id: section.id,
    settings: section.settings,
    media_gallery: media_gallery,
    product_details: product_details,
    additional_blocks: additional_blocks
  %}
{% enddoc %}

{% liquid
  # Determine render order based on media position
  if settings.desktop_media_position == 'left'
    assign render_order = 'media,product-details'
  else
    assign render_order = 'product-details,media'
  endif

  # Check if product has media
  assign product_has_media = true
  if product_media_size == 0
    assign product_has_media = false
  endif

  # Build product grid class
  assign product_grid_class = 'product-information__grid'

  if product_has_media == false
    assign product_grid_class = product_grid_class | append: ' product-information--media-none'
  elsif settings.desktop_media_position == 'right'
    assign product_grid_class = product_grid_class | append: ' product-information--media-right'
  else
    assign product_grid_class = product_grid_class | append: ' product-information--media-left'
  endif

  if settings.equal_columns
    assign product_grid_class = product_grid_class | append: ' product-information__grid--half'

    if settings.limit_details_width
      assign product_grid_class = product_grid_class | append: ' product-information__grid--limit-details'
    endif
  endif

  # Determine content width
  case settings.content_width
    when 'content-center-aligned'
      assign content_width = 'page-width'
    when 'content-full-width'
      assign content_width = 'full-width'
  endcase

  assign pi_title_size_desktop = settings.typography_product_title_size_desktop | default: 60
  assign pi_title_size_mobile = settings.typography_product_title_size_mobile | default: 40
  assign pi_title_weight = settings.typography_product_title_weight | default: '700'

  assign pi_price_size_desktop = settings.typography_product_price_size_desktop | default: 24
  assign pi_price_size_mobile = settings.typography_product_price_size_mobile | default: 18
  assign pi_price_weight = settings.typography_product_price_weight | default: '700'

  assign pi_variant_label_size_desktop = settings.typography_variant_labels_size_desktop | default: 14
  assign pi_variant_label_size_mobile = settings.typography_variant_labels_size_mobile | default: 14
  assign pi_variant_label_weight = settings.typography_variant_labels_weight | default: '600'

  assign pi_variant_value_size_desktop = settings.typography_variant_values_size_desktop | default: 14
  assign pi_variant_value_size_mobile = settings.typography_variant_values_size_mobile | default: 14
  assign pi_variant_value_weight = settings.typography_variant_values_weight | default: '500'

  assign pi_atc_size_desktop = settings.typography_add_to_cart_size_desktop | default: 14
  assign pi_atc_size_mobile = settings.typography_add_to_cart_size_mobile | default: 14
  assign pi_atc_weight = settings.typography_add_to_cart_weight | default: '700'

  assign pi_accordion_heading_size_desktop = settings.typography_accordion_heading_size_desktop | default: 14
  assign pi_accordion_heading_size_mobile = settings.typography_accordion_heading_size_mobile | default: 14
  assign pi_accordion_heading_weight = settings.typography_accordion_heading_weight | default: '700'

  assign pi_accordion_content_size_desktop = settings.typography_accordion_content_size_desktop | default: 14
  assign pi_accordion_content_size_mobile = settings.typography_accordion_content_size_mobile | default: 14
  assign pi_accordion_content_weight = settings.typography_accordion_content_weight | default: '400'

  assign pi_feature_icon_size_desktop = settings.typography_feature_icons_size_desktop | default: 14
  assign pi_feature_icon_size_mobile = settings.typography_feature_icons_size_mobile | default: 12
  assign pi_feature_icon_weight = settings.typography_feature_icons_weight | default: '600'

  assign pi_breadcrumbs_size_desktop = settings.typography_breadcrumbs_size_desktop | default: 14
  assign pi_breadcrumbs_size_mobile = settings.typography_breadcrumbs_size_mobile | default: 12
  assign pi_breadcrumbs_weight = settings.typography_breadcrumbs_weight | default: '400'

  assign pi_meta_size_desktop = settings.typography_product_meta_size_desktop | default: 14
  assign pi_meta_size_mobile = settings.typography_product_meta_size_mobile | default: 14
  assign pi_meta_weight = settings.typography_product_meta_weight | default: '400'
%}

<div class="section-background color-{{ settings.color_scheme }}"></div>
<div
  class="product-information section section--{{ content_width }} spacing-style color-{{ settings.color_scheme }} relative"
  style="{% render 'spacing-style', settings: settings %} --gap: {{ settings.gap }}px; --pi-title-size-desktop: {{ pi_title_size_desktop }}px; --pi-title-size-mobile: {{ pi_title_size_mobile }}px; --pi-title-weight: {{ pi_title_weight }}; --pi-price-size-desktop: {{ pi_price_size_desktop }}px; --pi-price-size-mobile: {{ pi_price_size_mobile }}px; --pi-price-weight: {{ pi_price_weight }}; --pi-variant-label-size-desktop: {{ pi_variant_label_size_desktop }}px; --pi-variant-label-size-mobile: {{ pi_variant_label_size_mobile }}px; --pi-variant-label-weight: {{ pi_variant_label_weight }}; --pi-variant-value-size-desktop: {{ pi_variant_value_size_desktop }}px; --pi-variant-value-size-mobile: {{ pi_variant_value_size_mobile }}px; --pi-variant-value-weight: {{ pi_variant_value_weight }}; --pi-atc-size-desktop: {{ pi_atc_size_desktop }}px; --pi-atc-size-mobile: {{ pi_atc_size_mobile }}px; --pi-atc-weight: {{ pi_atc_weight }}; --pi-accordion-heading-size-desktop: {{ pi_accordion_heading_size_desktop }}px; --pi-accordion-heading-size-mobile: {{ pi_accordion_heading_size_mobile }}px; --pi-accordion-heading-weight: {{ pi_accordion_heading_weight }}; --pi-accordion-content-size-desktop: {{ pi_accordion_content_size_desktop }}px; --pi-accordion-content-size-mobile: {{ pi_accordion_content_size_mobile }}px; --pi-accordion-content-weight: {{ pi_accordion_content_weight }}; --pi-feature-icon-size-desktop: {{ pi_feature_icon_size_desktop }}px; --pi-feature-icon-size-mobile: {{ pi_feature_icon_size_mobile }}px; --pi-feature-icon-weight: {{ pi_feature_icon_weight }}; --pi-breadcrumbs-size-desktop: {{ pi_breadcrumbs_size_desktop }}px; --pi-breadcrumbs-size-mobile: {{ pi_breadcrumbs_size_mobile }}px; --pi-breadcrumbs-weight: {{ pi_breadcrumbs_weight }}; --pi-meta-size-desktop: {{ pi_meta_size_desktop }}px; --pi-meta-size-mobile: {{ pi_meta_size_mobile }}px; --pi-meta-weight: {{ pi_meta_weight }};"
  data-testid="product-information"
>
  {% if settings.desktop_media_position == 'left' and product_has_media and request.page_type == 'product' %}
    {% assign product_href = '#ProductInformation-' | append: section_id %}
    {% render 'skip-to-content-link', href: product_href, text: 'accessibility.skip_to_product_info' %}
  {% endif %}
  <div
    class="{{ product_grid_class }}"
    data-product-grid-content
  >


    {% assign render_order_array = render_order | split: ',' %}
    {% capture media %}
      <div
        class="product-information__media"
        data-testid="product-information-media"
      >
        {{ media_gallery }}
      </div>
      

      {% assign m_style = product.metafields.custom.style.value %}
{% assign m_fabric = product.metafields.custom.fabric.value %}
{% assign m_fit = product.metafields.custom.fit.value %}


{% if m_style != blank or m_fabric != blank or m_fit != blank %}

<div id="ProductMetaCards-{{ section_id }}" class="product-meta-cards">

  <div class="product-meta-cards__track">

    {% if m_style != blank %}
      <button
        type="button"
        class="meta-card"
        data-meta-title="Style"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M12 3a2 2 0 0 0-2 2c0 1.1.9 2 2 2a2 2 0 0 0 2-2"></path>
          <path d="M12 7v3"></path>
          <path d="M12 10L4 16h16L12 10z"></path>
        </svg>

        <span>Style</span>

        <div class="meta-card-content" hidden>
          {{ m_style | newline_to_br }}
        </div>
      </button>
    {% endif %}

    {% if m_fabric != blank %}
      <button
        type="button"
        class="meta-card"
        data-meta-title="Fabric"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M4 4h16v16H4z"></path>
          <path d="M4 8h16"></path>
          <path d="M4 12h16"></path>
          <path d="M4 16h16"></path>
          <path d="M8 4v16"></path>
          <path d="M12 4v16"></path>
          <path d="M16 4v16"></path>
        </svg>

        <span>Fabric</span>

        <div class="meta-card-content" hidden>
          {{ m_fabric | newline_to_br }}
        </div>
      </button>
    {% endif %}

    {% if m_fit != blank %}
      <button
        type="button"
        class="meta-card"
        data-meta-title="Fit"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="3" y="8" width="18" height="8" rx="2"></rect>
          <path d="M7 8v4"></path>
          <path d="M11 8v4"></path>
          <path d="M15 8v4"></path>
        </svg>

        <span>Fit</span>

        <div class="meta-card-content" hidden>
          {{ m_fit | newline_to_br }}
        </div>
      </button>
    {% endif %}

  </div>

</div>

<dialog
  id="ProductMetaModal-{{ section_id }}"
  class="product-meta-modal"
>
  <div class="product-meta-modal__inner">

    <button
      type="button"
      class="product-meta-modal__close"
      aria-label="Close"
    >
      <span class="svg-wrapper">
        {{- 'icon-close.svg' | inline_asset_content -}}
      </span>
    </button>

    <h2 class="product-meta-modal__title"></h2>

    <div class="product-meta-modal__body"></div>

  </div>
</dialog>

{% endif %}




    {% endcapture %}

    {% for block in render_order_array %}
      {% if block == 'media' and product_has_media %}
        {{ media }}
      {% elsif block == 'product-details' %}
        {{ product_details }}
      {% endif %}
    {% endfor %}
  </div>

  {{ additional_blocks }}
</div>


<script>
document.addEventListener('DOMContentLoaded', function () {

  // Prevent any custom DOM manipulation inside Quick View
  const sectionId = "{{ section_id }}";
  const productInfo = document.getElementById('ProductInformation-' + sectionId);
  const isQuickView = productInfo && productInfo.closest('.quick-add-modal');
  if (isQuickView) return;

  const modal = document.getElementById('ProductMetaModal-' + sectionId);
  const cards = document.querySelectorAll('#ProductMetaCards-' + sectionId + ' .meta-card');
  const closeAnimationDuration = 300;
  let previousScrollY = 0;
  let previousBodyPaddingRight = '';

  let closeTimer;

  if (!modal) return;

  const titleEl = modal.querySelector('.product-meta-modal__title');
  const bodyEl = modal.querySelector('.product-meta-modal__body');
  const closeBtn = modal.querySelector('.product-meta-modal__close');
  const inner = modal.querySelector('.product-meta-modal__inner');

  function lockBodyScroll() {
    previousScrollY = window.scrollY;
    previousBodyPaddingRight = document.body.style.paddingRight || '';

    const scrollbarWidth = window.innerWidth - document.documentElement.clientWidth;
    if (scrollbarWidth > 0) {
      document.body.style.paddingRight = scrollbarWidth + 'px';
    }

    document.body.style.position = 'fixed';
    document.body.style.top = '-' + previousScrollY + 'px';
    document.body.style.width = '100%';
    document.body.style.overflow = 'hidden';
    document.body.classList.add('meta-modal-open');
  }

  function unlockBodyScroll() {
    document.body.style.position = '';
    document.body.style.top = '';
    document.body.style.width = '';
    document.body.style.overflow = '';
    document.body.style.paddingRight = previousBodyPaddingRight;
    document.body.classList.remove('meta-modal-open');
    window.scrollTo({ top: previousScrollY, behavior: 'instant' });
  }

function openModal(title, content) {
  titleEl.innerHTML = title;
  bodyEl.innerHTML = content;

  
  clearTimeout(closeTimer);

  if (!modal.open) {
    lockBodyScroll();

    if (typeof modal.showModal === 'function') {
      modal.showModal();
    } else {
      modal.setAttribute('open', '');
    }

    // Force browser paint before animation starts
    modal.offsetHeight;

    modal.classList.remove('dialog-closing');
    modal.classList.add('is-open');
    return;
  }

  modal.classList.remove('dialog-closing');
  modal.classList.add('is-open');
}

  function finalizeClose() {
    if (typeof modal.close === 'function' && modal.open) {
      modal.close();
    } else {
      modal.removeAttribute('open');
    }

    modal.classList.remove('dialog-closing');
    modal.classList.remove('is-open');
    unlockBodyScroll();
  }

  function closeModal() {
    if (!modal.open) return;

    
    modal.classList.remove('is-open');
    modal.classList.add('dialog-closing');
    clearTimeout(closeTimer);
    closeTimer = window.setTimeout(finalizeClose, closeAnimationDuration);
  }

  cards.forEach(function(card) {

    card.addEventListener('click', function(e) {

      e.preventDefault();
      e.stopPropagation();

      const title =
        this.dataset.metaTitle || '';

      const content =
        this.querySelector('.meta-card-content')?.innerHTML || '';

      openModal(title, content);

    });

  });

  if (closeBtn) {
    closeBtn.addEventListener('click', closeModal);
  }

  modal.addEventListener('click', function(e) {
    if (inner && !inner.contains(e.target)) {
      closeModal();
    }
  });

  modal.addEventListener('cancel', function(e) {
    e.preventDefault();
    closeModal();
  });

  document.addEventListener('keydown', function(e) {

    if (e.key === 'Escape' && modal.open) {
      closeModal();
    }

  });

});
</script>

{% stylesheet %}
  .product-information:not(.quick-add-modal__content .product-information) .product-details .text-block:is(.h1, .h2, .h3, .h4, .h5, .h6):has(h1) :is(h1, h2, h3, h4, h5, h6) {
    font-size: var(--pi-title-size-desktop);
    font-weight: var(--pi-title-weight);
    line-height: 1.1;
  }

  .product-information:not(.quick-add-modal__content .product-information) .product-details product-price :is(.price, .price-item--sale, .price-item--regular, .compare-at-price) {
    font-size: var(--pi-price-size-desktop);
    font-weight: var(--pi-price-weight);
    line-height: 1.2;
  }

  .product-information:not(.quick-add-modal__content .product-information) .product-details .variant-option legend {
    font-size: var(--pi-variant-label-size-desktop);
    font-weight: var(--pi-variant-label-weight);
  }

  .product-information:not(.quick-add-modal__content .product-information) .product-details :is(.variant-option__button-label__text, .variant-option__swatch-value) {
    font-size: var(--pi-variant-value-size-desktop);
    font-weight: var(--pi-variant-value-weight);
  }

  .product-information:not(.quick-add-modal__content .product-information) .product-details .add-to-cart-button {
    font-size: var(--pi-atc-size-desktop);
    font-weight: var(--pi-atc-weight);
  }

  .product-information:not(.quick-add-modal__content .product-information) .product-details .details__header,
  .product-information:not(.quick-add-modal__content .product-information) .product-details .details__header > * {
    font-size: var(--pi-accordion-heading-size-desktop);
    font-weight: var(--pi-accordion-heading-weight);
  }

  .product-information:not(.quick-add-modal__content .product-information) .product-details .details-content,
  .product-information:not(.quick-add-modal__content .product-information) .product-details .details-content :is(p, li, span, strong) {
    font-size: var(--pi-accordion-content-size-desktop);
    font-weight: var(--pi-accordion-content-weight);
  }

  .product-information:not(.quick-add-modal__content .product-information) .product-meta-cards .meta-card span {
    font-size: var(--pi-feature-icon-size-desktop);
    font-weight: var(--pi-feature-icon-weight);
  }

  #shopify-section-{{ section_id }} :is(.breadcrumbs, .breadcrumb, nav[aria-label='breadcrumb'], nav[aria-label='Breadcrumb']) :is(a, span, li) {
    font-size: var(--pi-breadcrumbs-size-desktop);
    font-weight: var(--pi-breadcrumbs-weight);
  }

  .product-information:not(.quick-add-modal__content .product-information) :is(
      product-sku-component,
      product-sku-component *,
      product-inventory,
      product-inventory *,
      .product-inventory__text,
      .quantity-label,
      .quantity-rules,
      .product-form-text__error,
      .tax-note,
      .volume-pricing__title,
      .volume-pricing__row,
      .pickup-availability-drawer,
      .pickup-availability-preview,
      .product-meta-modal__body
    ) {
    font-size: var(--pi-meta-size-desktop);
    font-weight: var(--pi-meta-weight);
  }

  .product-information {
    gap: var(--gap) 0;
  }

  /* Base grid layout */
  .product-information__grid {
    display: flex;
    grid-template-columns: subgrid;
    grid-column: 1 / -1;
    
    flex-direction: column;
  }

  /* Default column positions */
  .product-details {
    order: 1;
  }

  .product-information__media {
    order: 0;
    width: 0;
    min-width: 100%;
  }

  .product-information__media .product-media-gallery__placeholder-image {
    width: 100%;
    height: 100%;
  }

  .product-information__bottom-content {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* Mobile styles */
  @media screen and (max-width: 749px) {
    .product-information:not(.quick-add-modal__content .product-information) .product-details .text-block:is(.h1, .h2, .h3, .h4, .h5, .h6):has(h1) :is(h1, h2, h3, h4, h5, h6) {
      font-size: var(--pi-title-size-mobile);
    }

    .product-information:not(.quick-add-modal__content .product-information) .product-details product-price :is(.price, .price-item--sale, .price-item--regular, .compare-at-price) {
      font-size: var(--pi-price-size-mobile);
    }

    .product-information:not(.quick-add-modal__content .product-information) .product-details .variant-option legend {
      font-size: var(--pi-variant-label-size-mobile);
    }

    .product-information:not(.quick-add-modal__content .product-information) .product-details :is(.variant-option__button-label__text, .variant-option__swatch-value) {
      font-size: var(--pi-variant-value-size-mobile);
    }

    .product-information:not(.quick-add-modal__content .product-information) .product-details .add-to-cart-button {
      font-size: var(--pi-atc-size-mobile);
    }

    .product-information:not(.quick-add-modal__content .product-information) .product-details .details__header,
    .product-information:not(.quick-add-modal__content .product-information) .product-details .details__header > * {
      font-size: var(--pi-accordion-heading-size-mobile);
    }

    .product-information:not(.quick-add-modal__content .product-information) .product-details .details-content,
    .product-information:not(.quick-add-modal__content .product-information) .product-details .details-content :is(p, li, span, strong) {
      font-size: var(--pi-accordion-content-size-mobile);
    }

    .product-information:not(.quick-add-modal__content .product-information) .product-meta-cards .meta-card span {
      font-size: var(--pi-feature-icon-size-mobile);
    }

    #shopify-section-{{ section_id }} :is(.breadcrumbs, .breadcrumb, nav[aria-label='breadcrumb'], nav[aria-label='Breadcrumb']) :is(a, span, li) {
      font-size: var(--pi-breadcrumbs-size-mobile);
    }

    .product-information:not(.quick-add-modal__content .product-information) :is(
        product-sku-component,
        product-sku-component *,
        product-inventory,
        product-inventory *,
        .product-inventory__text,
        .quantity-label,
        .quantity-rules,
        .product-form-text__error,
        .tax-note,
        .volume-pricing__title,
        .volume-pricing__row,
        .pickup-availability-drawer,
        .pickup-availability-preview,
        .product-meta-modal__body
      ) {
      font-size: var(--pi-meta-size-mobile);
    }

    .product-information:not(.quick-add-modal__content .product-information) .product-information__media {
      grid-column: 1 / -1;
      grid-row: 1;
    }

    .product-information:not(.quick-add-modal__content .product-information) .product-details {
      grid-column: 2 / 3;
      grid-row: 2;
    }

    .product-information:not(.quick-add-modal__content .product-information) .product-information__bottom-content {
      grid-column: 2 / 3;
      grid-row: 3;
      margin-top: 0px;
    }
  }

  /* Desktop styles */
  @media screen and (min-width: 750px) {
    .product-information:not(.quick-add-modal__content .product-information) .product-information__grid {
      grid-column: 2;
    }

    /* Premium Editorial Gallery on Desktop */
    .product-information:not(.quick-add-modal__content .product-information) .product-information__media media-gallery slideshow-controls,
    .product-information:not(.quick-add-modal__content .product-information) .product-information__media media-gallery .thumbnail-list {
      display: none !important;
    }
    
    .product-information:not(.quick-add-modal__content .product-information) .product-information__media media-gallery slideshow-container {
      display: block !important;
    }

    .product-information:not(.quick-add-modal__content .product-information) .product-information__media media-gallery slideshow-slides {
      display: flex !important;
      flex-direction: column !important;
      gap: 20px !important;
      transform: none !important;
      scroll-snap-type: none !important;
    }

    .product-information:not(.quick-add-modal__content .product-information) .product-information__media media-gallery slideshow-slide {
      display: block !important;
      position: relative !important;
      opacity: 1 !important;
      visibility: visible !important;
      width: 100% !important;
      height: auto !important;
      transform: none !important;
    }

    /* Position when there is no media */
    .product-information:not(.quick-add-modal__content .product-information) .product-information__grid.product-information--media-none {
      .product-details {
        width: var(--narrow-content-width);
        margin: 0 auto;
      }
    }

    /* Position when there is media */
    .product-information:not(.quick-add-modal__content .product-information) .product-information__grid:not(.product-information--media-none) {
      /* Media on the left side */
      &.product-information--media-left {
        grid-template-columns: 1fr min(50vw, var(--sidebar-width));

        .product-information:not(.quick-add-modal__content .product-information) .product-information__media {
          padding-right: calc(var(--gap, 0) / 2);
          grid-column: 1;
          grid-row: 1;
        }

        .product-information:not(.quick-add-modal__content .product-information) .product-information__bottom-content {
          padding-right: calc(var(--gap, 0) / 2);
          grid-column: 1;
          grid-row: 2;
          padding-top: 40px;
        }

        .product-information:not(.quick-add-modal__content .product-information) .product-details {
          padding-left: calc(var(--gap, 0) / 2);
          grid-column: 2;
          grid-row: 1 / span 2;
        }

        &:has(.media-gallery--extend) {
          grid-column: 1 / 3;
        }
      }

      /* Media on the right side */
      &.product-information--media-right {
        grid-template-columns: min(50vw, var(--sidebar-width)) 1fr;

        .product-information:not(.quick-add-modal__content .product-information) .product-information__media {
          padding-left: calc(var(--gap, 0) / 2);
          order: 1;
          grid-column: 2;
          grid-row: 1;
        }

        .product-information:not(.quick-add-modal__content .product-information) .product-information__bottom-content {
          padding-left: calc(var(--gap, 0) / 2);
          grid-column: 2;
          grid-row: 2;
          padding-top: 40px;
        }

        .product-information:not(.quick-add-modal__content .product-information) .product-details {
          padding-right: calc(var(--gap, 0) / 2);
          order: 0;
          grid-column: 1;
          grid-row: 1 / span 2;
        }

        &:has(.media-gallery--extend) {
          grid-column: 2 / -1;
        }
      }

      /* Equal width columns */
      &.product-information__grid--half,
      &.product-information__grid--half:has(.media-gallery--extend) {
        grid-column: 1 / -1;
        grid-template-columns:
          var(--full-page-grid-margin) calc(var(--full-page-grid-central-column-width) / 2) calc(
            var(--full-page-grid-central-column-width) / 2
          )
          var(--full-page-grid-margin);

        &.product-information--media-left {
          .product-information:not(.quick-add-modal__content .product-information) .product-information__media {
            grid-column: 2 / 3;
            grid-row: 1;

            &:has(.media-gallery--extend) {
              grid-column: 1 / 3;
            }
          }
          
          .product-information:not(.quick-add-modal__content .product-information) .product-information__bottom-content {
            grid-column: 2 / 3;
            grid-row: 2;
            padding-top: 40px;
                    width: 50%;
        margin: auto;
          }

          .product-information:not(.quick-add-modal__content .product-information) .product-details {
            grid-column: 3 / 4;
            grid-row: 1 / span 2;
          }
        }

        &.product-information--media-right {
          .product-information:not(.quick-add-modal__content .product-information) .product-information__media {
            grid-column: 3 / 4;
            grid-row: 1;

            &:has(.media-gallery--extend) {
              grid-column: 3 / -1;
            }
          }
          
          .product-information:not(.quick-add-modal__content .product-information) .product-information__bottom-content {
            grid-column: 3 / 4;
            grid-row: 2;
            padding-top: 40px;
          }

          .product-information:not(.quick-add-modal__content .product-information) .product-details {
            grid-column: 2 / 3;
            grid-row: 1 / span 2;
          }
        }
      }
    }

    /* Handle full width section */
    .section--full-width .product-information:not(.quick-add-modal__content .product-information) {
      .product-information__grid:not(.product-information--media-none) {
        &.product-information--media-left,
        &.product-information--media-right {
          grid-column: 1 / -1;
        }

        &.product-information--media-left .product-details {
          padding-inline-end: var(--padding-lg);
        }

        &.product-information--media-right .product-details {
          padding-inline-start: var(--padding-lg);
        }

        &.product-information__grid--half.product-information--media-left {
          .product-information:not(.quick-add-modal__content .product-information) .product-information__media {
            grid-column: 1 / 3;
            grid-row: 1;
          }

          .product-information:not(.quick-add-modal__content .product-information) .product-information__bottom-content {
            grid-column: 1 / 3;
            grid-row: 2;
            padding-top: 40px;
          }

          .product-information:not(.quick-add-modal__content .product-information) .product-details {
            grid-column: 3 / -1;
            grid-row: 1 / span 2;
          }
        }

        &.product-information__grid--half.product-information--media-right {
          .product-information:not(.quick-add-modal__content .product-information) .product-information__media {
            grid-column: 3 / -1;
            grid-row: 1;
          }

          .product-information:not(.quick-add-modal__content .product-information) .product-information__bottom-content {
            grid-column: 3 / -1;
            grid-row: 2;
            padding-top: 40px;
          }

          .product-information:not(.quick-add-modal__content .product-information) .product-details {
            grid-column: 1 / 3;
            grid-row: 1 / span 2;
          }
        }
      }
    }
  }

  /* Wider sidebar for large screens */
  @media screen and (min-width: 1200px) {
    .product-information:not(.quick-add-modal__content .product-information) .product-information__grid:not(
        .product-information__grid--half,
        .product-information--media-none
      ).product-information--media-left {
      grid-template-columns: 2fr 1fr;
    }

    .product-information:not(.quick-add-modal__content .product-information) .product-information__grid:not(
        .product-information__grid--half,
        .product-information--media-none
      ).product-information--media-right {
      grid-template-columns: 1fr 2fr;
    }
  }

  .product-information:not(.quick-add-modal__content .product-information) .product-information__grid--limit-details .product-details > .group-block {
    --details-max-width: var(--sidebar-width);
    max-width: var(--details-max-width);
  }

  @media screen and (min-width: 1600px) {
    .product-information:not(.quick-add-modal__content .product-information) .product-information__grid--limit-details .product-details > .group-block {
      --details-max-width: 32rem;
    }
  }

  /* If the header is sticky, make product details content stick underneath the header */
  body:has(#header-group #header-component[data-sticky-state='active']) .product-details.sticky-content--desktop {
    --sticky-header-offset: var(--header-height);
  }

  /* Hide specific blocks and layout overrides in Quick View Modal */
  .quick-add-modal__content .product-information__bottom-content,
  .quick-add-modal__content .product-meta-cards {
    display: none !important;
  }

  /* Meta Cards & Modal Styling */
  .product-meta-cards {
    display: block;
    display: flex !important;
    visibility: visible !important;
    opacity: 1 !important;
    width: 100%;
    margin: 0px 0;
    flex-direction: column;
  }
  .product-meta-cards__track {
    display: flex;
    display: flex !important;
    visibility: visible !important;
    opacity: 1 !important;
    gap: 16px;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .product-meta-cards__track::-webkit-scrollbar {
    display: none;
  }
  @media screen and (min-width: 990px) {
    .product-meta-cards__track {
      align-items: center;
      overflow: visible;
  
      overflow: visible !important;
    }
  }

  @media screen and (max-width: 989px) {
    .product-meta-cards__track {
      flex-direction: row;
      overflow-x: auto;
      justify-content: center;
      flex-direction: row !important;
      overflow-x: auto !important;
      padding-bottom: 5px;
    }
  }
  .meta-card {
    flex: 0 0 auto;
    width: 80px;
    height: 80px;
    background: #fff;

    box-shadow: 0 4px 12px rgba(0,0,0,.08);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    border: 1px solid rgba(0,0,0,0.05);
    padding: 0;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .meta-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(0,0,0,.12);
  }
  .meta-card svg {
    width: 24px;
    height: 24px;
    color: #0c4168; 
  }
  .meta-card span {
    font-size: 12px;
    font-weight: 600;
    color: #0c4168;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .meta-card-content {
    display: none;
  }
  body.meta-modal-open {
    overflow: hidden;
  }
  dialog.product-meta-modal {
    border: none;
    background: transparent;
    padding: 0;
    margin: 0;
    max-width: none;
    max-height: none;
    width: 100vw;
    height: 100dvh;
    overflow: hidden; /* prevent the dialog itself from being the scroll container */
  }
  dialog.product-meta-modal[open],
  dialog.product-meta-modal:modal {
    position: fixed;
    inset: 0;
    margin: 0;
    padding: 0;
    border: none;
    max-width: none;
    max-height: none;
    width: 100vw;
    height: 100dvh;
    display: flex;
    align-items: stretch;
    justify-content: flex-start;
    overflow: hidden;
  }
  dialog.product-meta-modal::backdrop {
    background: rgba(0, 0, 0, 0.5) !important;
  }
  .product-meta-modal__inner {
    background: #fff;
    position: relative;
    width: clamp(420px, 34vw, 560px);
    height: 100dvh;
    border-radius: 0;
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.2);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transform: none;
    will-change: transform, opacity;
    backface-visibility: hidden;
  }
  .product-meta-modal__close {
    position: absolute;
    top: 20px;
    right: 20px;
    z-index: 2;
    background: transparent;
    border: none;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: opacity 0.2s ease;
    color: #111;
    flex-shrink: 0;
  }
  .product-meta-modal__close:hover {
    opacity: 0.7;
  }
  .product-meta-modal__close .svg-wrapper {
    width: 20px;
    height: 20px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .product-meta-modal__close .svg-wrapper svg {
    width: 100%;
    height: 100%;
  }
  .product-meta-modal__title {
    margin: 0;
    padding: 32px 72px 20px 32px;
    font-size: 24px;
    color: #0c4168;
    text-transform: uppercase;
    flex-shrink: 0;
    flex: 0 0 auto;
  }
  .product-meta-modal__body {
    font-size: 14px;
    line-height: 1.6;
    color: #333;
    white-space: pre-line;
    flex: 1 1 auto;
    min-height: 0;
    overflow-y: auto;
    padding: 0 32px 32px;
    -webkit-overflow-scrolling: touch;
  }
  @media screen and (min-width: 750px) {
    .product-meta-modal__inner {
      transform: translateX(-100%);
    }
    .product-meta-modal.is-open .product-meta-modal__inner {
      animation: product-meta-drawer-in-left 0.32s ease forwards;
    }
    .product-meta-modal.dialog-closing .product-meta-modal__inner {
      animation: product-meta-drawer-out-left 0.28s ease forwards;
    }
    @keyframes product-meta-drawer-in-left {
      from {
        transform: translateX(-100%);
      }
      to {
        transform: translateX(0);
      }
    }
    @keyframes product-meta-drawer-out-left {
      from {
        transform: translateX(0);
      }
      to {
        transform: translateX(-100%);
      }
    }
  }
  @media screen and (max-width: 1199px) {
    .product-meta-modal__inner {
      width: min(44vw, 560px);
    }
  }
  @media screen and (max-width: 749px) {
    dialog.product-meta-modal {
      position: fixed !important;
      bottom: 0 !important;
      left: 0 !important;
      right: 0 !important;
      top: auto !important;
      margin: 0 auto !important;
      width: 100% !important;
      max-height: 85vh !important;
      overflow: hidden !important;
      padding: 0 !important;
      height: auto !important;
      background: transparent !important;
      border: none !important;
    }
    dialog.product-meta-modal[open],
    dialog.product-meta-modal:modal {
      position: fixed !important;
