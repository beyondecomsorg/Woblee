{% comment %}
  Hero Slideshow Section
  Premium full-width banner with Splide slider, 3 CTA buttons, full customizer control
  ✅ Desktop + Mobile separate images
  ✅ Video background support (MP4/WebM) with optional poster
{% endcomment %}

{% assign s = section.settings %}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@splidejs/splide@4.1.4/dist/css/splide.min.css">

<style>
#shopify-section-{{ section.id }} {
  --font-heading: Helvetica, Arial, sans-serif;
  --font-body: Aptos, Arial, Helvetica, sans-serif;

  --brand-blue: #0C4168;
  --brand-lime: #ffffffff;
  --brand-white: #FFFFFF;
  --brand-grey: #626261;
  --brand-burgundy: #851828;

  --btn-bg: var(--brand-lime);
  --btn-text: var(--brand-blue);
  --btn-border: var(--brand-lime);
  --btn-hover-bg: var(--brand-blue);
  --btn-hover-text: var(--brand-lime);

  --heading-color: var(--brand-white);
  --subtext-color: var(--brand-white);

  --section-height-desktop: 780px;
  --section-height-mobile: 620px;
}
.hs-section .splide__arrow {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  color: #000;
  opacity: 1;
  background: transparent;
  transition: all 0.3s ease;
}

.hs-section .splide__arrow svg {
  width: 18px;
  height: 18px;
  fill: #000;
  transition: all 0.3s ease;
}

.hs-section .splide__arrow:hover {
  {% comment %} background: #0C4168;
  border-color: #0C4168;
  box-shadow: 0 8px 25px rgba(12, 65, 104, 0.35); {% endcomment %}
}

.hs-section .splide__arrow:hover svg {
  fill: #fff;
}

.hs-section .splide__arrow:focus-visible {
  outline: none;
  box-shadow:
    0 0 0 4px rgba(12, 65, 104, 0.15),
    0 8px 25px rgba(12, 65, 104, 0.35);
}
{% comment %} .hs-section .splide__arrow {
  animation: arrowPulse 3s infinite;
} {% endcomment %}

@keyframes arrowPulse {
  0% {
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
  }
  50% {
    box-shadow: 0 4px 28px rgba(12,65,104,0.20);
  }
  100% {
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
  }
}

.hs-section {
  position: relative;
  width: 100%;
  font-family: var(--font-body);
  overflow: hidden;
  background: var(--brand-blue);
}

.hs-section .splide__track {
  overflow: hidden;
}

.hs-slide {
  position: relative;
  width: 100%;
  height: var(--section-height-desktop);
  overflow: hidden;
  background: var(--brand-blue);
}

.hs-slide__bg,
.hs-slide__video {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.hs-slide__bg {
  object-position: center center;
}

.hs-slide__bg--desktop {
  display: block;
}

.hs-slide__bg--mobile {
  display: none;
}

.hs-slide__video-wrap {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  overflow: hidden;
}

.hs-slide__video {
  object-position: center center;
}

.hs-slide__overlay {
  position: absolute;
  inset: 0;
  {% comment %} background: linear-gradient(
    90deg,
    rgba(12, 65, 104, 0.92) 0%,
    rgba(12, 65, 104, 0.72) 40%,
    rgba(12, 65, 104, 0.35) 70%,
    rgba(12, 65, 104, 0.12) 100%
  ); {% endcomment %}
  pointer-events: none;
  z-index: 1;
}

.hs-slide__caption {
  position: absolute;
  z-index: 2;
  max-width: 68%;
  padding: 24px 32px;
  color: var(--brand-white);
  {% case s.caption_position %}
    {% when 'top_left' %}
      top: {{ s.content_offset_v }}%;
      left: {{ s.content_offset_h }}%;
      transform: none;
    {% when 'top_center' %}
      top: {{ s.content_offset_v }}%;
      left: 50%;
      transform: translateX(-50%);
    {% when 'top_right' %}
      top: {{ s.content_offset_v }}%;
      right: {{ s.content_offset_h }}%;
      transform: none;
    {% when 'middle_left' %}
      top: 50%;
      left: {{ s.content_offset_h }}%;
      transform: translateY(-50%);
    {% when 'middle_center' %}
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
    {% when 'middle_right' %}
      top: 50%;
      right: {{ s.content_offset_h }}%;
      transform: translateY(-50%);
    {% when 'bottom_left' %}
      bottom: {{ s.content_offset_v }}%;
      left: {{ s.content_offset_h }}%;
      transform: none;
    {% when 'bottom_center' %}
      bottom: {{ s.content_offset_v }}%;
      left: 50%;
      transform: translateX(-50%);
    {% when 'bottom_right' %}
      bottom: {{ s.content_offset_v }}%;
      right: {{ s.content_offset_h }}%;
      transform: none;
  {% endcase %}
}

.hs-slide__eyebrow {
  font-family: var(--font-body);
  font-size: 12px;
  line-height: 1.2;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  color: var(--brand-lime);
  margin: 0 0 16px;
  font-weight: 700;
}

.hs-slide__heading {
  font-family: Helvetica, Arial, sans-serif;
  font-size: 48px;
  font-weight: 700;
  line-height: 0.95;
  letter-spacing: -0.04em;
  text-align: left;
  text-transform: uppercase;
  color: var(--brand-white);
  margin: 0 0 20px;
}

.hs-slide__subtext {
  font-family: Helvetica, Arial, sans-serif;
  font-size: 15px;
  line-height: 1.7;
  color: var(--brand-white);
  margin: 0 0 32px;
  font-weight: 500;
  max-width: 560px;
  opacity: 0.94;
}

.hs-slide__buttons {
  display: flex;
  flex-wrap: wrap;
  gap: {{ s.button_gap }}px;
  {% case s.button_align %}
    {% when 'center' %} justify-content: center;
    {% when 'right' %} justify-content: flex-end;
    {% else %} justify-content: flex-start;
  {% endcase %}
}

.hs-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 52px;
  padding: 14px 34px;
  background: var(--btn-bg);
  color: var(--btn-text);
  font-family: var(--font-heading);
  font-size: 12px;
  font-weight: 800;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  text-decoration: none;
  white-space: nowrap;
  transition: background 0.3s ease, color 0.3s ease, border-color 0.3s ease, transform 0.2s ease;
  cursor: pointer;
  text-align: center;
  border-radius: 0;
  min-width: 180px;
}

.hs-btn:hover {
  background: var(--btn-hover-bg);
  color: var(--btn-hover-text);
  transform: translateY(-2px);
}

.hs-section .splide__arrow {
  opacity: 1;
  width: 48px;
  height: 48px;
}

.hs-section .splide__arrow svg {
  fill: var(--brand-lime);
}

{% comment %} .hs-section .splide__arrow:hover {
  background: var(--brand-lime);
} {% endcomment %}

.hs-section .splide__arrow:hover svg {
  fill: var(--brand-blue);
}

.hs-section .splide__pagination__page {
  background: var(--brand-white);
  opacity: 0.45;
  width: 8px;
  height: 8px;
}

.hs-section .splide__pagination__page.is-active {
  {% comment %} background: var(--brand-lime); {% endcomment %}
  opacity: 1;
  transform: scale(1.3);
}

@media (max-width: 768px) {
  .hs-slide {
    height: var(--section-height-mobile);
  }
  .hs-slide__buttons{
  flex-wrap: nowrap; 
  }

  .hs-slide__bg--desktop {
    display: none;
  }
.hs-btn.mobile-hide{
 display: none;
}
  .hs-slide__bg--mobile {
    display: block;
  }

  .hs-slide__heading{
  text-align: left;
 font-size: 32px !important;

}
  
  .hs-slide__caption {
    max-width: 100%;
    padding: 20px 16px;
bottom: -2%;


    {% if s.mobile_caption_below %}
      position: static;
      transform: none;
      background: var(--brand-blue);
    {% endif %}
  }

  .hs-slide__eyebrow {
    font-size: 11px;
    letter-spacing: 0.18em;
    margin-bottom: 12px;
  }

  .hs-slide__heading {
    font-size: clamp(32px, 10vw, 44px);
    line-height: 0.98;
    letter-spacing: -0.03em;
    margin-bottom: 16px;
  }

  .hs-slide__subtext {
    font-size: 14px;
    line-height: 1.6;
    margin-bottom: 24px;
    max-width: 100%;
  }

  .hs-slide__buttons {
    gap: 12px;
  }

  .hs-btn {
    width: 100%;
    min-width: 0;
    font-size: 9px;
    min-height: 35px;
    padding: 0px;
  }

  .hs-section .splide__arrow {
    width: 40px;
    height: 40px;
  }
}
</style>

<section
  class="hs-section"
  id="hs-{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-section-type="hero-slideshow"
>
  <div
    class="splide"
    data-hs-splide
    data-autoplay="{{ s.autoplay }}"
    data-autoplay-speed="{{ s.autoplay_speed }}"
    data-transition="{{ s.transition_type }}"
    data-show-arrows="{{ s.show_arrows }}"
    data-show-dots="{{ s.show_dots }}"
  >
    <div class="splide__track">
      <ul class="splide__list">
        {% for block in section.blocks %}
          {% assign b = block.settings %}

          {%- comment -%}
            Determine media type priority:
            1. Video (if video_url_mp4 or video_url_webm is set)
            2. Image (desktop + optional mobile)
          {%- endcomment -%}

          {% assign has_video = false %}
          {% if b.video_url_mp4 != blank or b.video_url_webm != blank %}
            {% assign has_video = true %}
          {% endif %}

          <li class="splide__slide" {{ block.shopify_attributes }}>
            <div class="hs-slide">

              {% if has_video %}
                {%- comment -%} ── VIDEO BACKGROUND ── {%- endcomment -%}
                <div class="hs-slide__video-wrap">
                  <video
                    class="hs-slide__video"
                    autoplay
                    muted
                    loop
                    playsinline
                    {% if b.video_poster != blank %}
                      poster="{{ b.video_poster | image_url: width: 2400 }}"
                    {% elsif b.image != blank %}
                      poster="{{ b.image | image_url: width: 2400 }}"
                    {% endif %}
                  >
                    {% if b.video_url_mp4 != blank %}
                      <source src="{{ b.video_url_mp4 }}" type="video/mp4">
                    {% endif %}
                    {% if b.video_url_webm != blank %}
                      <source src="{{ b.video_url_webm }}" type="video/webm">
                    {% endif %}
                    {% comment %} Fallback image if video can't play {% endcomment %}
                    {% if b.image != blank %}
                      {{ b.image | image_url: width: 2400 | image_tag:
                        class: 'hs-slide__bg hs-slide__bg--desktop',
                        loading: 'lazy',
                        widths: '800,1200,1600,2000,2400',
                        sizes: '100vw'
                      }}
                    {% endif %}
                  </video>
                </div>

              {% else %}
                {%- comment -%} ── DESKTOP IMAGE ── {%- endcomment -%}
                {% if b.image != blank %}
                  {{ b.image | image_url: width: 2400 | image_tag:
                    class: 'hs-slide__bg hs-slide__bg--desktop',
                    loading: 'eager',
                    widths: '800,1200,1600,2000,2400',
                    sizes: '100vw',
                    alt: b.image.alt
                  }}
                {% else %}
                  {{ 'lifestyle-1' | placeholder_svg_tag: 'hs-slide__bg hs-slide__bg--desktop placeholder-svg' }}
                {% endif %}

                {%- comment -%} ── MOBILE IMAGE (falls back to desktop if not set) ── {%- endcomment -%}
                {% if b.mobile_image != blank %}
                  {{ b.mobile_image | image_url: width: 1200 | image_tag:
                    class: 'hs-slide__bg hs-slide__bg--mobile',
                    loading: 'eager',
                    widths: '400,600,800,1000,1200',
                    sizes: '100vw',
                    alt: b.mobile_image.alt
                  }}
                {% else %}
                  {% comment %}
                    No mobile image set — clone the desktop image with mobile class
                    so CSS swap still works cleanly.
                  {% endcomment %}
                  {% if b.image != blank %}
                    {{ b.image | image_url: width: 1200 | image_tag:
                      class: 'hs-slide__bg hs-slide__bg--mobile',
                      loading: 'eager',
                      widths: '400,600,800,1000,1200',
                      sizes: '100vw',
                      alt: b.image.alt
                    }}
                  {% else %}
                    {{ 'lifestyle-1' | placeholder_svg_tag: 'hs-slide__bg hs-slide__bg--mobile placeholder-svg' }}
                  {% endif %}
                {% endif %}

              {% endif %}

              {% comment %} Overlay {% endcomment %}
              <div class="hs-slide__overlay"></div>

              {% comment %} Caption {% endcomment %}
              {% unless b.hide_content %}
                <div class="hs-slide__caption">

                  {% if b.eyebrow != blank %}
                    <p class="hs-slide__eyebrow">{{ b.eyebrow }}</p>
                  {% endif %}

                  {% if b.heading != blank %}
                    <h2 class="hs-slide__heading">{{ b.heading }}</h2>
                  {% endif %}

                  {% if b.subtext != blank %}
                    <p class="hs-slide__subtext">{{ b.subtext }}</p>
                  {% endif %}

                  {% comment %} 3 CTA buttons {% endcomment %}
                  {% assign has_btn = false %}
                  {% if b.btn1_label != blank %}{% assign has_btn = true %}{% endif %}
                  {% if b.btn2_label != blank %}{% assign has_btn = true %}{% endif %}
                  {% if b.btn3_label != blank %}{% assign has_btn = true %}{% endif %}

                  {% if has_btn %}
                    <div class="hs-slide__buttons">

                      {% if b.btn1_label != blank %}
                        <a
                          href="{{ b.btn1_link | default: '#' }}"
                          class="hs-btn"
                          {% if b.btn1_new_tab %}target="_blank" rel="noopener"{% endif %}
                          style="
                            {% if b.btn1_custom_bg != blank %}background:{{ b.btn1_custom_bg }};border-color:{{ b.btn1_custom_bg }};{% endif %}
                            {% if b.btn1_custom_text != blank %}color:{{ b.btn1_custom_text }};{% endif %}
                          "
                        >{{ b.btn1_label }}</a>
                      {% endif %}

                      {% if b.btn2_label != blank %}
                        <a
                          href="{{ b.btn2_link | default: '#' }}"
                          class="hs-btn"
                          {% if b.btn2_new_tab %}target="_blank" rel="noopener"{% endif %}
                          style="
                            {% if b.btn2_custom_bg != blank %}background:{{ b.btn2_custom_bg }};border-color:{{ b.btn2_custom_bg }};{% endif %}
                            {% if b.btn2_custom_text != blank %}color:{{ b.btn2_custom_text }};{% endif %}
                          "
                        >{{ b.btn2_label }}</a>
                      {% endif %}

                      {% if b.btn3_label != blank %}
                        <a
                          href="{{ b.btn3_link | default: '#' }}"
                          class="hs-btn mobile-hide"
                          {% if b.btn3_new_tab %}target="_blank" rel="noopener"{% endif %}
                          style="
                            {% if b.btn3_custom_bg != blank %}background:{{ b.btn3_custom_bg }};border-color:{{ b.btn3_custom_bg }};{% endif %}
                            {% if b.btn3_custom_text != blank %}color:{{ b.btn3_custom_text }};{% endif %}
                          "
                        >{{ b.btn3_label }}</a>
                      {% endif %}

                    </div>
                  {% endif %}
                </div>
              {% endunless %}

            </div>
          </li>
        {% endfor %}
      </ul>
    </div>
  </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/@splidejs/splide@4.1.4/dist/js/splide.min.js" defer></script>

<script>
(function() {
  function initSlider() {
    var el = document.querySelector('#hs-{{ section.id }} [data-hs-splide]');
    if (!el) return;

    var autoplay   = el.dataset.autoplay === 'true';
    var speed      = parseInt(el.dataset.autoplaySpeed) || 5000;
    var transition = el.dataset.transition || 'slide';
    var arrows     = el.dataset.showArrows === 'true';
    var dots       = el.dataset.showDots === 'true';

    var splide = new Splide(el, {
      type        : transition === 'fade' ? 'fade' : 'loop',
      rewind      : true,
      perPage     : 1,
      autoplay    : autoplay,
      interval    : speed,
      pauseOnHover: true,
      speed       : {{ s.transition_speed }},
      arrows      : arrows,
      pagination  : dots,
      drag        : true,
      lazyLoad    : 'nearby',
    });

    splide.mount();

    // Pause/resume autoplay when a video slide is active
    splide.on('active', function(slide) {
      var video = slide.slide.querySelector('video');
      if (video) {
        video.play().catch(function(){});
        // Optionally pause autoplay while video is playing
        if (autoplay && {{ s.video_pause_autoplay }}) {
          splide.Components.Autoplay.pause();
        }
      }
    });

    splide.on('inactive', function(slide) {
      var video = slide.slide.querySelector('video');
      if (video) {
        video.pause();
        video.currentTime = 0;
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSlider);
  } else {
    var attempts = 0;
    var check = setInterval(function() {
      attempts++;
      if (typeof Splide !== 'undefined') {
        clearInterval(check);
        initSlider();
      }
      if (attempts > 30) clearInterval(check);
    }, 100);
  }
})();
</script>

{% schema %}
{
  "name": "Hero Slideshow Custom",
  "tag": "section",
  "class": "hs-section-wrapper",
  "settings": [

    {
      "type": "header",
      "content": "━━  Slideshow Behaviour  ━━"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Auto-play slides",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Auto-play speed (ms)",
      "min": 2000,
      "max": 9000,
      "step": 500,
      "default": 5000
    },
    {
      "type": "select",
      "id": "transition_type",
      "label": "Transition style",
      "options": [
        { "value": "slide", "label": "Slide" },
        { "value": "fade",  "label": "Fade"  }
      ],
      "default": "slide"
    },
    {
      "type": "range",
      "id": "transition_speed",
      "label": "Transition duration (ms)",
      "min": 300,
      "max": 1500,
      "step": 100,
      "default": 700
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show navigation arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show pagination dots",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "video_pause_autoplay",
      "label": "Pause slideshow auto-play on video slides",
      "default": false,
      "info": "When enabled, the slideshow will pause auto-advancing while a video slide is active."
    },

    {
      "type": "header",
      "content": "━━  Overlay  ━━"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay colour",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity (%)",
      "min": 0,
      "max": 90,
      "step": 5,
      "default": 25
    },
    {
      "type": "range",
      "id": "eyebrow_font_size",
      "label": "Eyebrow font size (px)",
      "min": 10,
      "max": 20,
      "step": 1,
      "default": 12
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading font size (px)",
      "min": 24,
      "max": 120,
      "step": 2,
      "default": 64
    },
    {
      "type": "select",
      "id": "heading_font_weight",
      "label": "Heading font weight",
      "options": [
        { "value": "300", "label": "Light 300" },
        { "value": "400", "label": "Regular 400" },
        { "value": "500", "label": "Medium 500" },
        { "value": "600", "label": "Semibold 600" },
        { "value": "700", "label": "Bold 700" },
        { "value": "800", "label": "Extra Bold 800" }
      ],
      "default": "400"
    },
    {
      "type": "range",
      "id": "subtext_font_size",
      "label": "Subtext font size (px)",
      "min": 12,
      "max": 28,
      "step": 1,
      "default": 16
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading colour",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "subtext_color",
      "label": "Subtext colour",
      "default": "#f0ede8"
    },

    {
      "type": "header",
      "content": "━━  Content Position  ━━"
    },
    {
      "type": "select",
      "id": "caption_position",
      "label": "Caption position",
      "options": [
        { "value": "top_left",      "label": "Top left"      },
        { "value": "top_center",    "label": "Top center"    },
        { "value": "top_right",     "label": "Top right"     },
        { "value": "middle_left",   "label": "Middle left"   },
        { "value": "middle_center", "label": "Middle center" },
        { "value": "middle_right",  "label": "Middle right"  },
        { "value": "bottom_left",   "label": "Bottom left"   },
        { "value": "bottom_center", "label": "Bottom center" },
        { "value": "bottom_right",  "label": "Bottom right"  }
      ],
      "default": "bottom_left"
    },
    {
      "type": "range",
      "id": "content_offset_h",
      "label": "Horizontal offset (% from edge)",
      "min": 0,
      "max": 20,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "content_offset_v",
      "label": "Vertical offset (% from edge)",
      "min": 0,
      "max": 20,
      "step": 1,
      "default": 8
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Content max-width (px)",
      "min": 300,
      "max": 900,
      "step": 20,
      "default": 600
    },
    {
      "type": "checkbox",
      "id": "caption_bg_show",
      "label": "Show content background",
      "default": false
    },
    {
      "type": "color",
      "id": "caption_bg_color",
      "label": "Content background colour",
      "default": "rgba(0,0,0,0.4)"
    },

    {
      "type": "header",
      "content": "━━  Buttons — Global Style  ━━"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button shape",
      "options": [
        { "value": "sharp",   "label": "Sharp / square" },
        { "value": "rounded", "label": "Rounded"        },
        { "value": "pill",    "label": "Pill"            }
      ],
      "default": "sharp"
    },
