{% comment %}
  Product Extended Gallery Section
  Displays the remaining product images (from the 4th onward) when the split gallery setting is active.
{% endcomment %}

{%- if product.media.size > 3 -%}
  <div class="product-extended-gallery-wrapper" style="display: none;">
    <div class="page-width">
      <div class="product-extended-gallery">
        <div class="product-extended-gallery__grid">
          {%- for media in product.media offset: 3 -%}
            <div class="product-extended-gallery__item">
              {%- case media.media_type -%}
                {%- when 'image' -%}
                  {{ media | image_url: width: 1200 | image_tag: 
                    loading: 'lazy', 
                    class: 'product-extended-gallery__image',
                    sizes: '(min-width: 990px) calc((100vw - 100px) / 3), (min-width: 750px) calc((100vw - 60px) / 2), calc(100vw - 30px)' 
                  }}
                {%- when 'video' -%}
                  {{ media | video_tag: autoplay: true, loop: true, muted: true, controls: true, class: 'product-extended-gallery__video' }}
                {%- else -%}
                  {{ media | media_tag: class: 'product-extended-gallery__media' }}
              {%- endcase -%}
            </div>
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Product extended gallery",
  "tag": "section",
  "class": "section",
  "settings": [],
  "presets": [
    {
      "name": "Product extended gallery"
    }
  ]
}
{% endschema %}

{% stylesheet %}
  .product-extended-gallery {
    padding-top: var(--padding-lg, 40px);
    padding-bottom: var(--padding-lg, 40px);
  }

  .product-extended-gallery__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    width: 100%;
  }

  @media only screen and (min-width: 768px){
      .product-extended-gallery__grid {
    margin: auto;
    width: 80%;
  }
  body .product-extended-gallery__image{
    object-fit: contain !important;
    aspect-radio: auto !important;
  }
  }

  .product-extended-gallery__item {
    position: relative;
    overflow: hidden;
    border-radius: var(--style-border-radius-popover, 8px);
    background-color: var(--color-background-secondary, #f9f9f9);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-extended-gallery__image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: fill;

  }

  .product-extended-gallery__video {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 1 / 1.25;
  }

  .product-extended-gallery__media {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 1 / 1.25;
  }

  @media screen and (max-width: 989px) {
    .product-extended-gallery__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 15px;
    }
  }

  @media screen and (max-width: 749px) {
    .product-extended-gallery__grid {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }
{% endstylesheet %}
