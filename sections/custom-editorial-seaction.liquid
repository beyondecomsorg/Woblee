{% comment %}
  Editorial Split Section
  - Left: large hero image with logo, stats text, body text, CTA link
  - Right: 2x2 grid of images each with caption + EXPLORE link
{% endcomment %}

<section class="ess-section" id="ess-{{ section.id }}">
  <div class="ess-inner">

    {% comment %} LEFT PANEL {% endcomment %}
    <div class="ess-left">
      {% if section.settings.left_image != blank %}
        <img
          src="{{ section.settings.left_image | image_url: width: 1000 }}"
          alt="{{ section.settings.heading | escape }}"
          class="ess-left-img"
          loading="lazy"
          width="1000"
        >
      {% else %}
        <div class="ess-left-placeholder">
          {{ 'lifestyle-1' | placeholder_svg_tag: 'ess-svg' }}
        </div>
      {% endif %}

      <div class="ess-left-content">
        {% if section.settings.logo != blank %}
          <img
            src="{{ section.settings.logo | image_url: width: 200 }}"
            alt="Logo"
            class="ess-logo"
            loading="lazy"
            width="200"
          >
        {% endif %}

        {% if section.settings.stats_text != blank %}
          <div class="ess-stats">{{ section.settings.stats_text }}</div>
        {% endif %}

        {% if section.settings.body_text != blank %}
          <div class="ess-body">{{ section.settings.body_text }}</div>
        {% endif %}

        {% if section.settings.cta_label != blank %}
          <h2 class="ess-cta">
            {{ section.settings.cta_label }}
          </h2>
        {% endif %}
      </div>
    </div>

    {% comment %} RIGHT PANEL — 2x2 grid {% endcomment %}
    <div class="ess-right">
      {% for block in section.blocks %}
        {% if block.type == 'grid_item' %}
          <a class="ess-grid-item" href="{{ block.settings.link | default: '#' }}" {{ block.shopify_attributes }}>
            {% if block.settings.image != blank %}
              <img
                src="{{ block.settings.image | image_url: width: 700 }}"
                alt="{{ block.settings.caption | escape }}"
                class="ess-grid-img"
                loading="lazy"
                width="700"
              >
            {% else %}
              <div class="ess-grid-placeholder">
                {{ 'lifestyle-2' | placeholder_svg_tag: 'ess-svg' }}
              </div>
            {% endif %}

            <div class="ess-grid-overlay">
              <div class="ess-grid-bottom">
                {% if block.settings.caption != blank %}
                  <p class="ess-caption">{{ block.settings.caption }}</p>
                {% endif %}
                {% if block.settings.explore_label != blank %}
                  <span class="ess-explore">
                    {{ block.settings.explore_label }}
                  </span>
                {% endif %}
              </div>
            </div>
          </a>
        {% endif %}
      {% endfor %}
    </div>

  </div>
</section>

<style>
#ess-{{ section.id }} {
  --ess-bg: {{ section.settings.background_color }};
  --ess-gap: {{ section.settings.gap }}px;
  --ess-left-ratio: {{ section.settings.left_width }};
  --ess-max-width: {{ section.settings.max_width }}px;
  --ess-h-padding: {{ section.settings.h_padding }}px;
  --ess-mobile-side-padding: {{ section.settings.mobile_side_padding }}px;

  --ess-stats-color: {{ section.settings.stats_color }};
  --ess-body-color: {{ section.settings.body_color }};
  --ess-cta-color: {{ section.settings.cta_color }};
  --ess-cta-hover-color: {{ section.settings.cta_hover_color }};
  --ess-caption-color: {{ section.settings.caption_color }};
  --ess-explore-color: {{ section.settings.explore_color }};
  --ess-left-panel-bg: {{ section.settings.left_panel_bg }};
  --ess-grid-item-bg: {{ section.settings.grid_item_bg }};
  --ess-placeholder-bg: {{ section.settings.placeholder_bg }};
  --ess-overlay-start: {{ section.settings.overlay_start_color }};
  --ess-overlay-end: {{ section.settings.overlay_end_color }};

  --ess-padding-top: {{ section.settings.padding_top }}px;
  --ess-padding-bottom: {{ section.settings.padding_bottom }}px;
   --ess-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
  --ess-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
  --ess-left-min-height: {{ section.settings.left_min_height }}px;
  --ess-left-min-height-mobile: {{ section.settings.left_min_height_mobile }}px;
  --ess-left-min-height-small: {{ section.settings.left_min_height_small_mobile }}px;
  --ess-left-content-padding: {{ section.settings.left_content_padding }}px;
  --ess-left-content-padding-mobile: {{ section.settings.left_content_padding_mobile }}px;
  --ess-logo-width: {{ section.settings.logo_width }}px;
  --ess-logo-margin-bottom: {{ section.settings.logo_margin_bottom }}px;
  --ess-stats-size: {{ section.settings.stats_size }}px;
  --ess-stats-size-mobile: {{ section.settings.stats_size_mobile }}px;
  --ess-stats-weight: {{ section.settings.stats_weight }};
  --ess-stats-margin-bottom: {{ section.settings.stats_margin_bottom }}px;
  --ess-body-size: {{ section.settings.body_size }}px;
  --ess-body-size-mobile: {{ section.settings.body_size_mobile }}px;
  --ess-body-weight: {{ section.settings.body_weight }};
  --ess-body-margin-bottom: {{ section.settings.body_margin_bottom }}px;
  --ess-body-max-width: {{ section.settings.body_max_width }}px;
  --ess-cta-size: {{ section.settings.cta_size }}px;
  --ess-cta-size-mobile: {{ section.settings.cta_size_mobile }}px;
  --ess-cta-weight: {{ section.settings.cta_weight }};
  --ess-caption-size: {{ section.settings.caption_size }}px;
  --ess-caption-size-mobile: {{ section.settings.caption_size_mobile }}px;
  --ess-caption-weight: {{ section.settings.caption_weight }};
  --ess-grid-overlay-padding: {{ section.settings.grid_overlay_padding }}px;
  --ess-grid-overlay-padding-mobile: {{ section.settings.grid_overlay_padding_mobile }}px;
  --ess-grid-bottom-gap: {{ section.settings.grid_bottom_gap }}px;
  --ess-grid-item-ratio: {{ section.settings.grid_item_ratio }};
  --ess-explore-size: {{ section.settings.explore_size }}px;
  --ess-explore-size-mobile: {{ section.settings.explore_size_mobile }}px;
  --ess-explore-weight: {{ section.settings.explore_weight }};
  --ess-explore-width: {{ section.settings.explore_width_desktop }}px;
  --ess-explore-height: {{ section.settings.explore_height_desktop }}px;
  --ess-explore-width-mobile: {{ section.settings.explore_width_mobile }}px;
  --ess-explore-height-mobile: {{ section.settings.explore_height_mobile }}px;
  --ess-explore-padding-y: {{ section.settings.explore_padding_y }}px;
  --ess-explore-padding-x: {{ section.settings.explore_padding_x }}px;
  --ess-explore-padding-y-mobile: {{ section.settings.explore_padding_y_mobile }}px;
  --ess-explore-padding-x-mobile: {{ section.settings.explore_padding_x_mobile }}px;
  --ess-explore-radius: {{ section.settings.explore_radius }}px;
}

.ess-section {
  background: var(--ess-bg);
  padding: var(--ess-padding-top) 0px var(--ess-padding-bottom);
  font-family: var(--wb-font-body);
}

.ess-inner {
  display: grid;
  grid-template-columns: var(--ess-left-ratio) 1fr;
  gap: var(--ess-gap);
  max-width: var(--ess-max-width);
  margin: 0 auto;
  padding-left: var(--ess-h-padding);
  padding-right: var(--ess-h-padding);
  box-sizing: border-box;
}

/* LEFT */
.ess-left {
  position: relative;
  overflow: hidden;
  min-height: var(--ess-left-min-height);
  background: var(--ess-left-panel-bg);
}

.ess-left-img,
.ess-left-placeholder {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  position: absolute;
  inset: 0;
}

.ess-left-placeholder {
  background: var(--ess-placeholder-bg);
}

.ess-svg {
  width: 60px;
  height: 60px;
  opacity: 0.2;
}

.ess-left-content {
  position: relative;
  z-index: 2;
  padding: var(--ess-left-content-padding);
  display: flex;
  flex-direction: column;
  height: 100%;
  justify-content: flex-start;
}

.ess-logo {
  width: var(--ess-logo-width);
  height: auto;
  display: block;
  margin-bottom: var(--ess-logo-margin-bottom);
  object-fit: contain;
}

.ess-stats {
  font-family: Helvetica, Arial, sans-serif;
  font-size: var(--ess-stats-size);
  color: var(--ess-stats-color);
  line-height: var(--wb-line-relaxed);
  font-weight: var(--ess-stats-weight);
  margin-bottom: var(--ess-stats-margin-bottom);
  white-space: pre-line;
}

.ess-body {
  font-family: Helvetica, Arial, sans-serif;
  font-size: var(--ess-body-size);
  color: var(--ess-body-color);
  line-height: var(--wb-line-body);
  margin-bottom: var(--ess-body-margin-bottom);
  max-width: var(--ess-body-max-width);
  font-weight: var(--ess-body-weight);
}

.ess-cta {
  font-family: var(--wb-font-heading);
  font-size: 40px;
  font-weight: 700;
  color: var(--ess-cta-color);
  text-decoration: none;
  text-transform: uppercase;
  line-height: 1.1;
  letter-spacing: 0;
  margin: auto 0 0;
  margin-top: auto;
  align-self: flex-start;
}

/* RIGHT GRID */
.ess-right {
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-template-rows: 1fr 1fr;
  gap: var(--ess-gap);
}

.ess-grid-item {
  position: relative;
  overflow: hidden;
  display: block;
  text-decoration: none;
  background: var(--ess-grid-item-bg);
  aspect-ratio: var(--ess-grid-item-ratio);
}

.ess-grid-img,
.ess-grid-placeholder {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.5s ease;
}

.ess-grid-item:hover .ess-grid-img {
  transform: scale(1.05);
}

.ess-grid-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, var(--ess-overlay-start) 0%, var(--ess-overlay-end) 60%);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: var(--ess-grid-overlay-padding);
}

.ess-grid-bottom {
  display: flex;
  flex-direction: column;
  gap: var(--ess-grid-bottom-gap);
}

.ess-caption {
  font-family: Helvetica;
  font-size: var(--ess-caption-size);
  color: var(--ess-caption-color);
  margin: 0;
  line-height: var(--wb-line-body);
  font-weight: var(--ess-caption-weight);
}

.ess-explore:hover{
  background: {{ section.settings.explore_hover_bg }};
  color: {{ section.settings.explore_hover_text }};
}

.ess-explore {
  display: grid;
  text-align: center;
  align-items: center;
  gap: 10px;
  font-family: var(--wb-font-heading);
  font-size: var(--ess-explore-size);
  font-weight: var(--ess-explore-weight);
  text-transform: uppercase;
  line-height: 1;
  position: relative;
  cursor: pointer;
  transition: all 0.35s ease;
  padding: var(--ess-explore-padding-y) var(--ess-explore-padding-x);
  background: {{ section.settings.explore_bg }};
  color: {{ section.settings.explore_text_color }};
  box-shadow: 0 6px 18px rgba(0, 0, 0, 0.14);
  overflow: hidden;
  width: var(--ess-explore-width);
  min-width: var(--ess-explore-width);
  height: var(--ess-explore-height);
  min-height: var(--ess-explore-height);
  border-radius: var(--ess-explore-radius);
  box-sizing: border-box;
}


.ess-explore::before {
  content: "";
  position: absolute;
  inset: 0;
  transform: translateX(-100%);
  transition: transform 0.5s ease;
}

.ess-explore:hover {
  transform: translateY(-2px);
  background: {{ section.settings.explore_hover_bg }};
  color: {{ section.settings.explore_hover_text }};
  box-shadow: 0 10px 26px rgba(0, 0, 0, 0.22);
}

.ess-explore:hover::before {
  transform: translateX(100%);
}

.ess-explore-line {
  width: 30px;
  height: 2px;
  background: var(--wb-color-lime);
  border-radius: 999px;
  position: relative;
  transition: all 0.35s ease;
  flex-shrink: 0;
}

.ess-explore-line::after {
  content: "";
  position: absolute;
  right: -1px;
  top: 50%;
  width: 7px;
  height: 7px;
  border-top: 2px solid var(--wb-color-lime);
  border-right: 2px solid var(--wb-color-lime);
  transform: translateY(-50%) rotate(45deg);
  opacity: 0;
  transition: all 0.35s ease;
}

.ess-explore:hover .ess-explore-line {
  width: 40px;
  background: var(--wb-color-white);
}

.ess-explore:hover .ess-explore-line::after {
  opacity: 1;
  border-color: var(--wb-color-white);
}

.ess-explore:focus-visible {
  outline: none;
  box-shadow:
    0 0 0 4px rgba(33, 240, 16, 0.18),
    0 10px 26px rgba(0, 0, 0, 0.22);
}

.ess-explore-line {
  display: inline-block;
  width: 28px;
  height: 2px;
  background: var(--ess-explore-color);
  flex-shrink: 0;
}

/* MOBILE */
@media (max-width: 900px) {
  .ess-inner {
    grid-template-columns: 1fr;
  }
  .ess-explore{
    font-size: var(--ess-explore-size-mobile);
    width: var(--ess-explore-width-mobile);
    min-width: var(--ess-explore-width-mobile);
    height: var(--ess-explore-height-mobile);
    min-height: var(--ess-explore-height-mobile);
    padding: var(--ess-explore-padding-y-mobile) var(--ess-explore-padding-x-mobile);
  }
  .ess-cta{
    font-size: 24px;
  }
  .ess-stats {
    font-size: var(--ess-stats-size-mobile);
  }
  .ess-body {
    font-size: var(--ess-body-size-mobile);
  }
  .ess-caption {
    font-size: var(--ess-caption-size-mobile);
  }

  .ess-left {
    min-height: var(--ess-left-min-height-mobile);
    aspect-ratio: 3 / 4;
  }

  .ess-right {
    grid-template-columns: 1fr 1fr;
  }

  .ess-grid-item {
    aspect-ratio: 1 / 1;
  }
}

@media (max-width: 480px) {
  .ess-section {
    padding-top:  var(--ess-padding-top-mobile);
    padding-bottom: var(--ess-padding-bottom-mobile);
  }

  .ess-left {
    min-height: var(--ess-left-min-height-small);
  }

  .ess-inner {
    padding-left: var(--ess-mobile-side-padding);
    padding-right: var(--ess-mobile-side-padding);
  }

  .ess-left-content {
    padding: var(--ess-left-content-padding-mobile);
  }

  .ess-grid-overlay {
    padding: var(--ess-grid-overlay-padding-mobile);
  }
}
</style>

{% schema %}
{
  "name": "Custom Editorial Split",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max section width (px)",
      "min": 800,
      "max": 1800,
      "step": 20,
      "default": 1400
    },
    {
      "type": "text",
      "id": "left_width",
      "label": "Left panel width (CSS fraction)",
      "default": "1.1fr",
      "info": "e.g. '1fr', '1.1fr', '1.2fr'. Right panel fills remaining space."
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between panels / grid items (px)",
      "min": 2,
      "max": 24,
      "step": 1,
      "default": 6
    },

    {
      "type": "range",
      "id": "h_padding",
      "label": "Horizontal padding (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 20
    },
    {
      "type": "range",
      "id": "mobile_side_padding",
      "label": "Mobile side padding (px)",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Section top padding (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Section bottom padding (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40
    },
        {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Section Top padding mobile (px)",
      "min": 0,
      "max": 80,
