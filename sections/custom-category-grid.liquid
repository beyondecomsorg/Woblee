/* DESKTOP */
.shop-mobile{
  display:none;
}

h3.t4s-section-title.t4s-title.shop-bnd{
  color: {{ section.settings.heading_color }};
  font-size: {{ section.settings.heading_size }}px;
  font-weight: {{ section.settings.heading_weight }};
  font-family: var(--wb-font-heading, 'Bebas Neue', 'Arial Black', sans-serif);
  text-align: center;
  text-transform: uppercase;
  margin: 0 0 24px;
  letter-spacing: 0;
}

h3.t4s-section-title.t4s-title.shop-bnd span{
  letter-spacing:0;
}
/* MOBILE */
@media screen and (max-width: 749px){
.shop-mobile {
  padding-top: {{ section.settings.padding_top_mobile }}px !important;
  padding-bottom: {{ section.settings.padding_bottom_mobile }}px !important;
 
}
h3.t4s-section-title.t4s-title.shop-bnd span{
font-size: {{ section.settings.heading_size_mobile }}px;
}

  .shop-desk{
    display:none !important;
  }
h3.t4s-section-title.t4s-title.shop-bnd{
 font-size: {{ section.settings.heading_size_mobile }}px !important;
 font-weight: {{ section.settings.heading_weight_mobile }} !important;
}
  .shop-mobile{
    display:block;
    padding:4px 15px;
    padding-bottom: 0px !important;
  }

  .shop-mobile-track{
    display:flex;
    gap:12px;
    overflow-x:auto;
    scroll-snap-type:x mandatory;
    -webkit-overflow-scrolling:touch;
    scrollbar-width:none;
    padding-bottom:8px;
  }

  .shop-mobile-track::-webkit-scrollbar{
    display:none;
  }

  .shop-mobile-slide{
    flex:0 0 85%;
    scroll-snap-align:start;
    overflow:hidden;
    position:relative;
  }

  .shop-mobile-slide img{
    width:100%;
    height:320px;
    object-fit: fill;
    display:block;

  }

  .shop-mobile-dots{
    display:flex;
    justify-content:center;
    gap:8px;
    margin-top:12px;
  }

  .shop-mobile-dot{
    width:8px;
    height:8px;
    background:#d9d9d9;
    transition:all .25s ease;
  }

  .shop-mobile-dot.is-active{
    width:24px;
    background:#8f8f8f;
  }
  .t4s-container-fluid{
  padding: 0 !important;
}
}

</style>
<script>
document.addEventListener('DOMContentLoaded', function () {
  const track = document.getElementById('shopMobileTrack');
  const slides = track ? Array.from(track.querySelectorAll('.shop-mobile-slide')) : [];
  const dots = Array.from(document.querySelectorAll('.shop-mobile-dot'));

  if (!track || !slides.length || !dots.length) return;

  const setActive = (index) => {
    const safeIndex = Math.max(0, Math.min(index, dots.length - 1));
    dots.forEach((dot, i) => dot.classList.toggle('is-active', i === safeIndex));
  };

  const getNearestIndex = () => {
    const center = track.scrollLeft + track.clientWidth / 2;
    let nearestIndex = 0;
    let nearestDistance = Infinity;

    slides.forEach((slide, index) => {
      const slideCenter = slide.offsetLeft + slide.offsetWidth / 2;
      const distance = Math.abs(slideCenter - center);
      if (distance < nearestDistance) {
        nearestDistance = distance;
        nearestIndex = index;
      }
    });

    return nearestIndex;
  };

  let ticking = false;

  const handleScroll = () => {
    if (ticking) return;
    ticking = true;

    requestAnimationFrame(() => {
      setActive(getNearestIndex());
      ticking = false;
    });
  };

  track.addEventListener('scroll', handleScroll, { passive: true });
  window.addEventListener('resize', handleScroll);

  setActive(0);
});
</script>



