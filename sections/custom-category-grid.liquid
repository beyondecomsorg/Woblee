<!-- MOBILE -->

<div class="shop-mobile">

  <h3
    class="t4s-section-title t4s-title shop-bnd"
    style="
      font-size: {{ section.settings.heading_size_mobile }}px;
      font-weight: {{ section.settings.heading_weight_mobile }};
    "
  >
    <span>{{ section.settings.heading }}</span>
  </h3>

  <div class="shop-mobile-track">

    {% for i in (1..8) %}

      {% liquid
        assign desktop_key = 'desktop_image_' | append: i
        assign mobile_key = 'mobile_image_' | append: i
        assign link_key = 'link_' | append: i

        assign desktop_image = section.settings[desktop_key]
        assign mobile_image = section.settings[mobile_key]

        if mobile_image == blank
          assign mobile_image = desktop_image
        endif

        if desktop_image == blank
          assign desktop_image = mobile_image
        endif
      %}

      <a
        class="shop-mobile-slide"
        href="{{ section.settings[link_key] | default: '#' }}"
      >

        <picture>

          {% if mobile_image != blank %}
            <source
              media="(max-width:749px)"
              srcset="{{ mobile_image | image_url: width: 800 }}"
            >
          {% endif %}

          {% if desktop_image != blank %}
            {{
              desktop_image
              | image_url: width: 1200
              | image_tag
            }}
          {% endif %}

        </picture>

      </a>

    {% endfor %}

  </div>

</div>

</section>

