{% comment %}
  ============================================================
  WE ARE — Rotating Text Banner Section
  By Mime360
  ============================================================
{% endcomment %}

{%- liquid
  assign bg_color    = section.settings.background_color
  assign static_text = section.settings.static_text
  assign text_color  = section.settings.text_color
-%}

<section
  class="war-section"
  id="war-{{ section.id }}"
  style="
    --war-bg: {{ section.settings.background_color }};

    --war-static-color: {{ section.settings.static_text_color }};
    --war-rotating-color: {{ section.settings.rotating_text_color }};
    --war-sub-color: {{ section.settings.sub_text_color }};

    --war-static-size-desktop: {{ section.settings.static_text_size_desktop }}px;
    --war-rotating-size-desktop: {{ section.settings.rotating_text_size_desktop }}px;
    --war-sub-size-desktop: {{ section.settings.sub_text_size_desktop }}px;

    --war-static-size-mobile: {{ section.settings.static_text_size_mobile }}px;
    --war-rotating-size-mobile: {{ section.settings.rotating_text_size_mobile }}px;
    --war-sub-size-mobile: {{ section.settings.sub_text_size_mobile }}px;

    --war-static-weight-desktop: {{ section.settings.static_text_weight_desktop }};
    --war-rotating-weight-desktop: {{ section.settings.rotating_text_weight_desktop }};
    --war-sub-weight-desktop: {{ section.settings.sub_text_weight_desktop }};

    --war-static-weight-mobile: {{ section.settings.static_text_weight_mobile }};
    --war-rotating-weight-mobile: {{ section.settings.rotating_text_weight_mobile }};
    --war-sub-weight-mobile: {{ section.settings.sub_text_weight_mobile }};

    --war-pt: {{ section.settings.padding_top }}px;
    --war-pb: {{ section.settings.padding_bottom }}px;
  "
>

  <div class="war-inner">

    {% comment %} <span class="war-static">
      {{ section.settings.static_text }}
    </span> {% endcomment %}

    <div class="war-slot" aria-live="polite" aria-atomic="true">

      {%- assign first_phrase = section.blocks | where: 'type', 'phrase' | first -%}

      <span
        class="war-word war-word--visible"
        id="war-word-a-{{ section.id }}">
        {{ first_phrase.settings.word }}
      </span>

      <span
        class="war-word"
        id="war-word-b-{{ section.id }}">
      </span>

    </div>

  </div>

  <div
    class="war-sub"
    id="war-sub-{{ section.id }}">
    {{ first_phrase.settings.sub_text }}
  </div>

</section>

<!-- ═══════════════════════════════════════
  CSS
═══════════════════════════════════════ -->


<style>
.war-section {
  text-align: center;
}

.war-inner {
  width: 100%;
  justify-content: center;
  text-align: center;
}

.war-slot {
  width: 100%;
  justify-content: center;
  text-align: center;
}

.war-word {
  text-align: center;
  left: 50%;
  transform: translateY(110%);
}



.war-word--animating-in {
  left: 50%;
  transform: translateY(0);
}

.war-word--animating-out {
  left: 50%;
  transform: translateY(-110%);
}

.war-sub {
  width: 100%;
  text-align: center;
}

  .war-section {
  background: var(--war-bg);
  padding-top: var(--war-pt);
  padding-bottom: var(--war-pb);
  padding-left: 20px;
  padding-right: 20px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

/* Grain Overlay */
.war-section::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
  pointer-events: none;
  z-index: 0;
}

/* Layout */
.war-inner {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16px;
  flex-wrap: nowrap;
}

.war-slot {
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  min-width: 40px;
  justify-content: center;
}

/* ==========================
   DESKTOP TYPOGRAPHY
========================== */

.war-static {
  font-family: var(--wb-font-heading, 'Helvetica Neue', sans-serif);
  font-size: var(--war-static-size-desktop);
  font-weight: var(--war-static-weight-desktop);
  color: var(--war-static-color);
  line-height: 1;
  white-space: nowrap;
}

.war-word {
  font-family: var(--wb-font-heading, 'Helvetica Neue', sans-serif);
  font-size: var(--war-rotating-size-desktop);
  font-weight: var(--war-rotating-weight-desktop);
  color: var(--war-rotating-color);
  line-height: 1;
  white-space: nowrap;
  letter-spacing: -0.02em;

  position: absolute;
  left: 50%;
  transform: translate(-50%, 110%);
  opacity: 0;
  transition: none;
}

.war-sub {
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  text-align: center;

  position: relative;
  z-index: 1;

  font-family: Helvetica;
  font-size: var(--war-sub-size-desktop);
  font-weight: var(--war-sub-weight-desktop);
  color: var(--war-sub-color);

  opacity: 0.75;
  letter-spacing: 0.04em;
  min-height: 1.4em;

  transition: opacity 0.2s ease, transform 0.2s ease;
}

/* Animation States */
.war-word--visible {
  position: relative;
  transform: translateY(0);
  opacity: 1;
}

.war-word--enter {
  position: absolute;
  left: 50%;
  transform: translate(-50%, 110%);
  opacity: 0;
}

.war-word--animating-in {
  left: 50%;
  transform: translate(-50%, 0);
}

.war-word--animating-out {
  left: 50%;
  transform: translate(-50%, -110%);
    opacity: 0;
  transition:
    transform 0.45s cubic-bezier(0.55, 0, 0.8, 0.45),
    opacity 0.3s ease;
}

.war-sub.war-sub--hiding {
  opacity: 0;
  transform: translateY(5px);
}

/* ==========================
   MOBILE
========================== */

@media screen and (max-width: 767px) {

  .war-inner {
    gap: 8px;
  }

  .war-section {
    min-height: 50px;
  }

  .war-static {
    font-size: var(--war-static-size-mobile);
    font-weight: var(--war-static-weight-mobile);
  }

  .war-word {
    font-size: var(--war-rotating-size-mobile);
    font-weight: var(--war-rotating-weight-mobile);
  }

  .war-sub {
    font-size: var(--war-sub-size-mobile);
    font-weight: var(--war-sub-weight-mobile);
  }
}
</style>

<!-- ═══════════════════════════════════════
  JAVASCRIPT
═══════════════════════════════════════ -->
<script>
(function () {
  const INTERVAL = {{ section.settings.interval | times: 1000 }};
  const slot   = document.querySelector('#war-{{ section.id }} .war-slot');
  const subEl  = document.getElementById('war-sub-{{ section.id }}');
  if (!slot) return;

  /* Collect all phrases from schema blocks */
  const phrases = [
    {%- for block in section.blocks -%}
      {%- if block.type == 'phrase' -%}
        { word: {{ block.settings.word | json }}, sub: {{ block.settings.sub_text | json }} },
      {%- endif -%}
    {%- endfor -%}
  ];

  if (phrases.length <= 1) return; /* nothing to rotate */

  let current  = 0;
  let busy     = false;

  /* Two span elements — ping-pong between them */
  const elA = document.getElementById('war-word-a-{{ section.id }}');
  const elB = document.getElementById('war-word-b-{{ section.id }}');

  /* Size the slot to match word height so it never collapses */
  function sizeSlot() {
    const h = elA.offsetHeight || 52;
    slot.style.height = h + 'px';
    slot.style.minWidth = Math.max(elA.offsetWidth, elB.offsetWidth) + 'px';
  }
  sizeSlot();

  let activeEl  = elA; /* currently visible */
  let inactiveEl = elB; /* waiting off-screen */

  function rotate() {
    if (busy) return;
    busy = true;

    current = (current + 1) % phrases.length;
    const next = phrases[current];

    /* Prep inactive el with new word, position it below */
    inactiveEl.textContent = next.word;
    inactiveEl.className = 'war-word war-word--enter';

    /* Force reflow so transition fires */
    void inactiveEl.offsetWidth;

    /* Widen slot if new word is wider */
    const newW = inactiveEl.scrollWidth;
    const curW = activeEl.scrollWidth;

    /* Kick both animations simultaneously */
    activeEl.className  = 'war-word war-word--animating-out';
    inactiveEl.className = 'war-word war-word--animating-in';

    /* Swap sub-text */
    subEl.classList.add('war-sub--hiding');
    setTimeout(() => {
      subEl.textContent = next.sub;
      subEl.classList.remove('war-sub--hiding');
    }, 220);

    /* After animation: promote inactiveEl to visible, reset activeEl */
    setTimeout(() => {
      activeEl.className  = 'war-word'; /* hidden, off-screen */
      inactiveEl.className = 'war-word war-word--visible';

      /* Swap references */
      const tmp = activeEl;
      activeEl   = inactiveEl;
      inactiveEl = tmp;

      sizeSlot();
      busy = false;
    }, 520);
  }

  setInterval(rotate, INTERVAL);
})();
</script>

