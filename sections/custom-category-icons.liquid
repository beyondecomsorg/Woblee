{% comment %}
  Welcome Category Icons Section - Fully Customizable
  - All design values configurable via Theme Customizer
  - No reliance on external --wb-* CSS variables
  - Preserved hover image swap + hover text color
  - Preserved scroll behavior and performance
{% endcomment %}

<section class="wci-section" id="wci-{{ section.id }}">

  {% comment %} Heading {% endcomment %}
  {% if section.settings.heading != blank %}
    <h2 class="wci-heading">{{ section.settings.heading }}</h2>
  {% endif %}

  {% comment %} Subtext with optional inline link {% endcomment %}
  {% if section.settings.subtext_line_1 != blank or section.settings.subtext_line_2_before != blank %}
    <div class="wci-subtext">
      {% if section.settings.subtext_line_1 != blank %}
        <p>{{ section.settings.subtext_line_1 }}</p>
      {% endif %}
      {% if section.settings.subtext_line_2_before != blank %}
        <p>
          {{ section.settings.subtext_line_2_before }}
          {% if section.settings.inline_link_label != blank %}
            <a href="{{ section.settings.inline_link_url | default: '#' }}" class="wci-inline-link">{{ section.settings.inline_link_label }}</a>
          {% endif %}
          {{ section.settings.subtext_line_2_after }}
        </p>
      {% endif %}
    </div>
  {% endif %}

  {% comment %} Category Icons {% endcomment %}
  {% if section.blocks.size > 0 %}
    <div class="wci-scroll-wrap">
      <div class="wci-icons-row">
        {% for block in section.blocks %}
          {% if block.type == 'category' %}
            <a class="wci-item" href="{{ block.settings.link | default: '#' }}" {{ block.shopify_attributes }}>
              <div class="wci-circle" style="background-color: {{ block.settings.circle_bg }};">
                {% if block.settings.image != blank %}
                  <div class="wci-icon-stack">
                    <img
                      src="{{ block.settings.image | image_url: width: 200 }}"
                      alt="{{ block.settings.label | escape }}"
                      class="wci-icon-img wci-icon-img--default"
                      loading="lazy"
                      width="200"
                      height="200"
                    >
                    {% if block.settings.image_hover != blank %}
                      <img
                        src="{{ block.settings.image_hover | image_url: width: 200 }}"
                        alt="{{ block.settings.label | escape }}"
                        class="wci-icon-img wci-icon-img--hover"
                        loading="lazy"
                        width="200"
                        height="200"
                      >
                    {% endif %}
                  </div>
                {% else %}
                  <div class="wci-icon-placeholder">
                    {{ 'image' | placeholder_svg_tag: 'wci-placeholder-svg' }}
                  </div>
                {% endif %}
              </div>

              {% if block.settings.label != blank %}
                <span class="wci-label">{{ block.settings.label }}</span>
              {% endif %}
            </a>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  {% endif %}

  {% comment %} CTA Button {% endcomment %}
  {% if section.settings.cta_label != blank %}
    <div class="wci-cta-wrap">
      <a href="{{ section.settings.cta_url | default: '#' }}" class="wci-cta-btn">
        {{ section.settings.cta_label }}
      </a>
    </div>
  {% endif %}

</section>

<style>
#wci-{{ section.id }} {

  /* Colors */
  --wci-bg:                  {{ section.settings.background_color }};
  --wci-heading-color:       {{ section.settings.heading_color }};
  --wci-subtext-color:       {{ section.settings.subtext_color }};
  --wci-label-color:         {{ section.settings.label_color }};
  --wci-label-hover-color:   {{ section.settings.label_hover_color }};
  --wci-inline-color:        {{ section.settings.inline_link_color }};
  --wci-circle-border-color: {{ section.settings.circle_hover_border_color }};
  --wci-btn-bg:              {{ section.settings.btn_bg }};
  --wci-btn-color:           {{ section.settings.btn_text_color }};
  --wci-btn-border:          {{ section.settings.btn_border_color }};
  --wci-btn-hover-bg:        {{ section.settings.btn_hover_bg }};
  --wci-btn-hover-color:     {{ section.settings.btn_hover_text_color }};

  /* Spacing */
  --wci-padding-top:         {{ section.settings.padding_top }}px;
  --wci-padding-bottom:      {{ section.settings.padding_bottom }}px;
  --wci-icon-gap:            {{ section.settings.icon_gap }}px;
  --wci-icons-mb:            {{ section.settings.icons_margin_bottom }}px;
  --wci-heading-mb:          {{ section.settings.heading_margin_bottom }}px;
  --wci-subtext-mb:          {{ section.settings.subtext_margin_bottom }}px;
  --wci-item-gap:            {{ section.settings.icon_label_gap }}px;

  /* Circle */
  --wci-circle-size:         {{ section.settings.circle_size }}px;
  --wci-circle-size-mobile:  {{ section.settings.circle_size_mobile }}px;
  --wci-circle-border-width: {{ section.settings.circle_border_width }}px;
  --wci-circle-hover-lift:   {{ section.settings.circle_hover_lift }}px;
  --wci-circle-shadow:       {{ section.settings.circle_shadow_color }};
  --wci-circle-shadow-opacity: {{ section.settings.circle_shadow_opacity | times: 0.01 }};

  /* Heading Typography */
  --wci-heading-font:        {{ section.settings.heading_font }}, Helvetica, Arial, sans-serif;
  --wci-heading-size:        {{ section.settings.heading_size }}px;
  --wci-heading-size-mobile: {{ section.settings.heading_size_mobile }}px;
  --wci-heading-weight:      {{ section.settings.heading_weight }};
  --wci-heading-tracking:    {{ section.settings.heading_letter_spacing }}em;
  --wci-heading-lh:          {{ section.settings.heading_line_height | times: 0.01 }};
  --wci-heading-transform:   {{ section.settings.heading_transform }};

  /* Subtext Typography */
  --wci-body-font:           {{ section.settings.body_font }}, Arial, sans-serif;
  --wci-subtext-size:        {{ section.settings.subtext_size }}px;
  --wci-subtext-size-mobile: {{ section.settings.subtext_size_mobile }}px;
  --wci-subtext-weight:      {{ section.settings.subtext_weight }};
  --wci-subtext-lh:          {{ section.settings.subtext_line_height | times: 0.01 }};

  /* Label Typography */
  --wci-label-size:          {{ section.settings.label_size }}px;
  --wci-label-size-mobile:   {{ section.settings.label_size_mobile }}px;
  --wci-label-weight:        {{ section.settings.label_weight }};
  --wci-label-tracking:      {{ section.settings.label_letter_spacing }}em;
  --wci-label-transform:     {{ section.settings.label_transform }};

  /* Button */
  --wci-btn-font:            {{ section.settings.btn_font }}, Arial, sans-serif;
  --wci-btn-size:            {{ section.settings.btn_font_size }}px;
  --wci-btn-weight:          {{ section.settings.btn_font_weight }};
  --wci-btn-tracking:        {{ section.settings.btn_letter_spacing }}em;
  --wci-btn-transform:       {{ section.settings.btn_text_transform }};
  --wci-btn-padding-v:       {{ section.settings.btn_padding_v }}px;
  --wci-btn-padding-h:       {{ section.settings.btn_padding_h }}px;
  --wci-btn-radius:          {{ section.settings.btn_border_radius }}px;
  --wci-btn-border-width:    {{ section.settings.btn_border_width }}px;
  --wci-btn-min-height:      {{ section.settings.btn_min_height }}px;
  --wci-btn-hover-lift:      {{ section.settings.btn_hover_lift }}px;
}

.wci-section {
  background: var(--wci-bg);
  padding: var(--wci-padding-top) 20px var(--wci-padding-bottom);
  text-align: center;
  overflow: hidden;
}

/* Heading */
.wci-heading {
  font-family: var(--wci-heading-font);
  font-size: 42px;
  font-weight: var(--wci-heading-weight);
  color: var(--wci-heading-color);
  margin: 0 0 var(--wci-heading-mb);
  letter-spacing: var(--wci-heading-tracking);
  line-height: var(--wci-heading-lh);
  text-transform: var(--wci-heading-transform);
}

/* Subtext */
.wci-subtext {
  font-family: var(--wci-body-font);
  font-size: var(--wci-subtext-size);
  font-weight: var(--wci-subtext-weight);
  color: var(--wci-subtext-color);
  line-height: var(--wci-subtext-lh);
  margin: 0 auto var(--wci-subtext-mb);
  max-width: 680px;
}

.wci-subtext p {
  margin: 0 0 6px;
}

.wci-inline-link {
  color: var(--wci-inline-color);
  text-decoration: underline;
  text-underline-offset: 3px;
  font-weight: 700;
  transition: opacity 0.2s ease;
}

.wci-inline-link:hover {
  opacity: 0.75;
}

/* Scroll */
.wci-scroll-wrap {
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  margin-bottom: var(--wci-icons-mb);
}

.wci-scroll-wrap::-webkit-scrollbar {
  display: none;
}

.wci-icons-row {
  display: flex;
  justify-content: center;
  gap: var(--wci-icon-gap);
  padding: 8px 16px;
  min-width: max-content;
  margin: 0 auto;
}

/* Item */
.wci-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--wci-item-gap);
  text-decoration: none;
  flex-shrink: 0;
}

/* Circle */
.wci-circle {
  width: var(--wci-circle-size);
  height: var(--wci-circle-size);
  border-radius: 50%;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  border: var(--wci-circle-border-width) solid transparent;
  transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
}

.wci-item:hover .wci-circle {
  transform: translateY(calc(-1 * var(--wci-circle-hover-lift)));
  border-color: var(--wci-circle-border-color);
  box-shadow: 0 8px 24px color-mix(in srgb, var(--wci-circle-shadow) calc(var(--wci-circle-shadow-opacity) * 100%), transparent);
}

/* Image swap */
.wci-icon-stack {
  position: relative;
  width: 100%;
  height: 100%;
}

.wci-icon-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: opacity 0.25s ease, transform 0.25s ease;
}

.wci-icon-img--default {
  opacity: 1;
  z-index: 1;
}

.wci-icon-img--hover {
  opacity: 0;
  z-index: 2;
}

.wci-item:hover .wci-icon-img--default {
  opacity: 0;
}

.wci-item:hover .wci-icon-img--hover {
  opacity: 1;
}

.wci-icon-placeholder {
  width: 60%;
  height: 60%;
  opacity: 0.3;
}

.wci-placeholder-svg {
  width: 100%;
  height: 100%;
}

/* Label */
.wci-label {
  font-family: var(--wci-body-font);
  font-size: var(--wci-label-size);
  font-weight: var(--wci-label-weight);
  letter-spacing: var(--wci-label-tracking);
  text-transform: var(--wci-label-transform);
  color: var(--wci-label-color);
  white-space: nowrap;
  line-height: 1.2;
  transition: color 0.25s ease;
}

.wci-item:hover .wci-label {
  color: var(--wci-label-hover-color);
}

/* CTA Button */
.wci-cta-wrap {
  display: flex;
  justify-content: center;
}

.wci-cta-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: var(--wci-btn-min-height);
  padding: var(--wci-btn-padding-v) var(--wci-btn-padding-h);
  background: var(--wci-btn-bg);
  color: var(--wci-btn-color);
  border: var(--wci-btn-border-width) solid var(--wci-btn-border);
  font-family: var(--wci-btn-font);
  font-size: var(--wci-btn-size);
  font-weight: var(--wci-btn-weight);
  letter-spacing: var(--wci-btn-tracking);
  text-transform: var(--wci-btn-transform);
  text-decoration: none;
  border-radius: var(--wci-btn-radius);
  transition: background 0.25s ease, color 0.25s ease, transform 0.25s ease;
}

.wci-cta-btn:hover {
  background: var(--wci-btn-hover-bg);
  color: var(--wci-btn-hover-color);
  transform: translateY(calc(-1 * var(--wci-btn-hover-lift)));
}

.wci-item:focus-visible .wci-circle,
.wci-cta-btn:focus-visible {
  outline: 2px solid var(--wci-heading-color);
  outline-offset: 3px;
}

/* Mobile */
@media (max-width: 768px) {
  .wci-section {
    padding-left: 16px;
    padding-right: 16px;
    padding-bottom: 26px;
  }

  .wci-icons-row {
    justify-content: flex-start;
    padding-left: 0;
    padding-right: 0;
  }

  .wci-heading {
    font-size: var(--wci-heading-size-mobile);
  }

  .wci-subtext {
    font-size: var(--wci-subtext-size-mobile);
  }

  .wci-label {
    font-size: var(--wci-label-size-mobile);
  }

  .wci-circle {
    width: var(--wci-circle-size-mobile);
    height: var(--wci-circle-size-mobile);
  }


}
  .wci-cta-btn {
    width: 100%;
    height: 33px;
    padding-left: 20px !important;
    padding-right: 20px !important;

  }
  @media only screen and (min-width: 768px){
        max-width: 130px !important;
    padding-left: 20px !important;
    padding-right: 20px !important;
  }
  .wci-cta-btn {
  letter-spacing: 0;
  }
</style>

{% schema %}
{
  "name": "Custom Category Icons",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "─── Heading ───"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading text",
      "default": "Welcome to Woblee"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#0C4168"
    },
    {
      "type": "text",
      "id": "heading_font",
      "label": "Heading font family",
      "default": "Helvetica"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading font size — desktop (px)",
      "min": 24,
      "max": 96,
      "step": 2,
      "default": 52
