{% liquid
  assign section_id = 'trust-strip-' | append: section.id
%}

<section id="{{ section_id }}" class="trust-strip">

  {%- comment -%} Header stays inside page-width padding {%- endcomment -%}
  {% if section.settings.heading != blank or section.settings.subheading != blank %}
    <div class="trust-strip__header page-width">
      {% if section.settings.heading != blank %}
        <h2 class="trust-strip__heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p class="trust-strip__subheading">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>
  {% endif %}

  {%- comment -%} Track is FULL-BLEED — no page-width wrapper so no clipping {%- endcomment -%}
  <div class="trust-strip__track-wrap">

    {%- comment -%} Left / right fade masks {%- endcomment -%}
    {% comment %} <div class="trust-strip__fade trust-strip__fade--left"  aria-hidden="true"></div>
    <div class="trust-strip__fade trust-strip__fade--right" aria-hidden="true"></div> {% endcomment %}

    <div class="trust-strip__track" id="TrustTrack-{{ section.id }}" aria-label="Trust features">

      {%- comment -%} Set A — real blocks {%- endcomment -%}
      <div class="trust-strip__set" id="TrustSetA-{{ section.id }}" aria-hidden="false">
        {% for block in section.blocks %}
          <article class="trust-strip__card" {{ block.shopify_attributes }}>
            <div class="trust-strip__icon-wrap">
              {% if block.settings.icon != blank %}
                {{ block.settings.icon | image_url: width: 120 | image_tag: class: 'trust-strip__icon', loading: 'lazy', alt: block.settings.title }}
              {% else %}
                <span class="trust-strip__icon-fallback">✓</span>
              {% endif %}
            </div>
            <div class="trust-strip__content">
              {% if block.settings.title != blank %}
                <h3 class="trust-strip__title">{{ block.settings.title }}</h3>
              {% endif %}
              {% if block.settings.text != blank %}
                <p class="trust-strip__text">{{ block.settings.text }}</p>
              {% endif %}
            </div>
          </article>
        {% endfor %}
      </div>

      {%- comment -%} Set B — identical clone for seamless loop {%- endcomment -%}
      <div class="trust-strip__set" id="TrustSetB-{{ section.id }}" aria-hidden="true">
        {% for block in section.blocks %}
          <article class="trust-strip__card">
            <div class="trust-strip__icon-wrap">
              {% if block.settings.icon != blank %}
                {{ block.settings.icon | image_url: width: 120 | image_tag: class: 'trust-strip__icon', loading: 'lazy', alt: block.settings.title }}
              {% else %}
                <span class="trust-strip__icon-fallback">✓</span>
              {% endif %}
            </div>
            <div class="trust-strip__content">
              {% if block.settings.title != blank %}
                <h3 class="trust-strip__title">{{ block.settings.title }}</h3>
              {% endif %}
              {% if block.settings.text != blank %}
                <p class="trust-strip__text">{{ block.settings.text }}</p>
              {% endif %}
            </div>
          </article>
        {% endfor %}
      </div>

    </div>
  </div>

</section>

<style>
/* ── Section shell ──────────────────────────────────────────── */
.trust-strip {
  position: relative;
  overflow: hidden;
  background: {{ section.settings.section_bg }};
  
  margin: 10px 0;
  padding-top: 0px;
  padding-bottom: 18px;
}

/* ── Header (centered, page-width padding) ──────────────────── */
.trust-strip__header {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  margin-bottom: 20px;
  text-align: center;
}

.trust-strip__heading {
  margin: 0;
  font-family: var(--wb-font-heading);
  font-size: 32px;
  line-height: 1.05;
  font-weight: var(--wb-fw-extrabold);
  letter-spacing: var(--wb-letter-tight);
  text-transform: uppercase;
  color: var(--wb-color-blue, #0c4168);
  width:90%;
}

.trust-strip__subheading {
  margin: 0;
  max-width: 680px;
  font-family: var(--wb-font-body);
  font-size: clamp(13px, 1.1vw, 15px);
  line-height: 1.55;
  color: rgba(12, 65, 104, 0.60);
  font-weight: var(--wb-fw-medium);
}

/* ── Track wrapper — full bleed, clips overflow ─────────────── */
.trust-strip__track-wrap {
  position: relative;
  overflow: hidden;
  /* Prevent the very first card from being clipped on load */
  padding: 4px 0 6px;
}

/* ── Left / right fade masks ────────────────────────────────── */
.trust-strip__fade {
  position: absolute;
  top: 0;
  bottom: 0;
  width: 100px;
  z-index: 2;
  pointer-events: none;
}

.trust-strip__fade--left{
  background: linear-gradient(
    to right,
    {{ section.settings.fade_color }} 0%,
    transparent 100%
  );
}

.trust-strip__fade--right{
  background: linear-gradient(
    to left,
    {{ section.settings.fade_color }} 0%,
    transparent 100%
  );
}
/* ── Scrolling track ────────────────────────────────────────── */
.trust-strip__track {
  display: flex;
  width: max-content;
  /* JS drives translateX — no CSS animation here */
  will-change: transform;
  transform: translateX(0);
}

/* ── Set ────────────────────────────────────────────────────── */
.trust-strip__set {
  display: flex;
  gap: 14px;
  padding: 0 7px;
  flex-shrink: 0;
}

/* ── Card default (white) ───────────────────────────────────── */
.trust-strip__card {
  flex: 0 0 auto;
  width: 290px;
  min-height: 72px;
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 13px 18px;
  background: {{ section.settings.card_bg }};
  border-color: {{ section.settings.card_border }};
  box-shadow: 0 2px 10px rgba(12, 65, 104, 0.06);
  transition: background 0.26s ease, border-color 0.26s ease,
              box-shadow 0.26s ease, transform 0.22s ease;
  cursor: default;
  user-select: none;
}

/* ── Card hover — blue fill ─────────────────────────────────── */
.trust-strip__card:hover {
  background: {{ section.settings.card_hover_bg }};
  border-color: {{ section.settings.card_hover_border }};
  box-shadow: 0 8px 28px rgba(12, 65, 104, 0.22);
  transform: translateY(-3px) scale(1.025);
}

/* ── Icon wrap ──────────────────────────────────────────────── */
.trust-strip__icon-wrap {
  flex: 0 0 44px;
  width: 44px;
  height: 44px;
   background: {{ section.settings.icon_bg }};
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.26s ease;
}

.trust-strip__card:hover .trust-strip__icon-wrap {
  background: {{ section.settings.icon_hover_bg }};
}

.trust-strip__icon {
  width: 26px;
  height: 26px;
  object-fit: contain;
  display: block;
}

.trust-strip__icon-fallback {
  font-size: 20px;
  font-weight: 800;
  line-height: 1;
  color: var(--wb-color-blue, #0c4168);
  transition: color 0.26s ease;
}

/* Keep fallback tick dark on hover (sits on lime bg) */
.trust-strip__card:hover .trust-strip__icon-fallback {
  color: var(--wb-color-blue, #0c4168);
}

/* ── Content text ───────────────────────────────────────────── */
.trust-strip__content { flex: 1; min-width: 0; }

.trust-strip__title {
  margin: 0 0 3px;
  font-family: var(--wb-font-heading);
  font-size: 14.5px;
  line-height: 1.15;
  font-weight: var(--wb-fw-extrabold);
  letter-spacing: var(--wb-letter-tight);
  text-transform: uppercase;
  color: var(--wb-color-blue, #0c4168);
  transition: color 0.26s ease;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.trust-strip__card:hover .trust-strip__title,
.trust-strip__card:hover p.trust-strip__text{ 
  color: {{ section.settings.text_hover_color }} !important;

}
  .trust-strip__card:hover{
    color: {{ section.settings.text_hover_color }};
}
.trust-strip__text {
  margin: 0;
  font-family: var(--wb-font-body);
  font-size: 12.5px;
  line-height: 1.38;
  color: rgba(12, 65, 104, 0.62);
  font-weight: var(--wb-fw-medium);
  transition: color 0.26s ease;
}

.trust-strip__card:hover .trust-strip__text { color: rgba(255,255,255,0.85); }

/* ── Mobile ─────────────────────────────────────────────────── */
@media screen and (max-width: 749px) {
  .trust-strip {
    padding-top: 16px;
    padding-bottom: 14px;
  }

  .trust-strip__fade { width: 48px; }

  .trust-strip__card {
    width: 252px;
    padding: 11px 14px;

  }

  .trust-strip__title { font-size: 13.5px; }
  .trust-strip__text  { font-size: 12px; }
  .trust-strip__set   { gap: 10px; }
}

/* ── Reduced motion: static overflow scroll ─────────────────── */
@media (prefers-reduced-motion: reduce) {
  .trust-strip__track-wrap { overflow-x: auto; }
  .trust-strip__track      { transform: none !important; width: 100%; }
}
</style>
