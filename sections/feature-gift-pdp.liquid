      "id": "card_desc_font_size_desktop",
      "label": "Description Size Desktop (px)",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 15
    },
    {
      "type": "range",
      "id": "card_desc_font_size_mobile",
      "label": "Description Size Mobile (px)",
      "min": 10,
      "max": 22,
      "step": 1,
      "default": 14
    },
    {
      "type": "select",
      "id": "card_desc_font_weight",
      "label": "Description Font Weight",
      "default": "400",
      "options": [
        { "value": "400", "label": "400" },
        { "value": "500", "label": "500" },
        { "value": "600", "label": "600" },
        { "value": "700", "label": "700" },
        { "value": "800", "label": "800" }
      ]
