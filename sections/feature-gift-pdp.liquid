{% comment %}
  Section: Features Grid
  Style: Image + Heading + Description cards (dark navy bg or light bg)
  Layout: 2x3 or 3x2 grid, fully customizable
{% endcomment %}

{%- assign fg_images       = product.metafields.custom.product_features_images.value -%}
{%- assign fg_headings     = product.metafields.custom.product_features_text.value -%}
{%- assign fg_subheadings  = product.metafields.custom.product_features_subheading.value -%}
{%- assign fg_paragraphs   = product.metafields.custom.product_features_paragraph.value -%}

{%- if fg_headings != blank and fg_headings.size > 0 -%}

{{ 'features-grid.css' | asset_url | stylesheet_tag }}

<section
  class="features-grid"
  id="features-grid-{{ section.id }}"
  style="
    --fg-bg: {{ section.settings.bg_color }};
    --fg-text: {{ section.settings.text_color }};
    --fg-desc-color: {{ section.settings.desc_color }};
    --fg-heading-size: {{ section.settings.card_heading_font_size_desktop | default: section.settings.heading_font_size }}px;
    --fg-heading-size-mobile: {{ section.settings.card_heading_font_size_mobile | default: 18 }}px;
    --fg-heading-weight: {{ section.settings.card_heading_font_weight | default: '700' }};
    --fg-desc-size: {{ section.settings.card_desc_font_size_desktop | default: section.settings.desc_font_size }}px;
    --fg-desc-size-mobile: {{ section.settings.card_desc_font_size_mobile | default: 14 }}px;
    --fg-desc-weight: {{ section.settings.card_desc_font_weight | default: '400' }};
    --fg-section-title-size: {{ section.settings.section_heading_size }}px;
    --fg-section-title-size-mobile: {{ section.settings.section_heading_size_mobile | default: 26 }}px;
    --fg-section-title-weight: {{ section.settings.section_heading_weight | default: '700' }};
    --fg-section-sub-size: {{ section.settings.section_subheading_size_desktop | default: section.settings.desc_font_size }}px;
    --fg-section-sub-size-mobile: {{ section.settings.section_subheading_size_mobile | default: 14 }}px;
    --fg-section-sub-weight: {{ section.settings.section_subheading_weight | default: '400' }};
    --fg-img-size: {{ section.settings.image_size }}px;
    --fg-img-radius: {{ section.settings.image_radius }}%;
    --fg-card-bg: {{ section.settings.card_bg_color }};
    --fg-card-radius: {{ section.settings.card_radius }}px;
    --fg-card-padding: {{ section.settings.card_padding }}px;
    --fg-gap: {{ section.settings.grid_gap }}px;
    --fg-cols: {{ section.settings.columns }};
    --fg-section-padding-top: {{ section.settings.padding_top }}px;
    --fg-section-padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="features-grid__container">

    {% if section.settings.section_heading != blank or section.settings.section_subheading != blank %}
      <div class="features-grid__header">
        {% if section.settings.section_heading != blank %}
          <h2 class="features-grid__section-title">{{ section.settings.section_heading }}</h2>
        {% endif %}
        {% if section.settings.section_subheading != blank %}
          <p class="features-grid__section-sub">{{ section.settings.section_subheading }}</p>
        {% endif %}
      </div>
    {% endif %}
<div class="splide features-slider" id="features-slider-{{ section.id }}">
  <div class="splide__track">
    <ul class="splide__list">
      {% for heading in fg_headings %}
        {%- assign i = forloop.index0 -%}
        {%- assign fg_image = nil -%}
        {%- for img in fg_images -%}
          {%- if forloop.index0 == i -%}
            {%- assign fg_image = img -%}
            {%- break -%}
          {%- endif -%}
        {%- endfor -%}
        {%- assign fg_subheading = fg_subheadings[i] -%}
        {%- assign fg_paragraph = fg_paragraphs[i] -%}
        <li class="splide__slide">
          <div class="features-grid__card">
            {% if fg_image != blank %}
              <div class="features-grid__img-wrap">
                {% if fg_image.image %}
                  <img
                    src="{{ fg_image.image | image_url: width: 300 }}"
                    alt="{{ heading | escape }}"
                    loading="lazy"
                  >
                {% elsif fg_image.url %}
                  <img
                    src="{{ fg_image.url }}"
                    alt="{{ heading | escape }}"
                    loading="lazy"
                  >
                {% else %}
                  <img
                    src="{{ fg_image | image_url: width: 300 }}"
                    alt="{{ heading | escape }}"
                    loading="lazy"
                  >
                {% endif %}
              </div>
            {% endif %}

            <div class="features-grid__content-wrap">
              <h3 class="features-grid__heading">
                {{ heading }}
              </h3>

              {% if fg_subheading != blank %}
                <p class="features-grid__subheading">
                  {{ fg_subheading }}
                </p>
              {% endif %}

              {% if fg_paragraph != blank %}
                <div class="features-grid__desc">
                  {% assign sentences = fg_paragraph | split: '. ' %}
                  {% for sentence in sentences %}
                    {% assign trimmed_sentence = sentence | strip %}
                    {% if trimmed_sentence != blank %}
                      <p>
                        {{ trimmed_sentence }}{% unless trimmed_sentence contains '.' %}.{% endunless %}
                      </p>
                    {% endif %}
                  {% endfor %}
                </div>
              {% endif %}
            </div>
          </div>
        </li>
      {% endfor %}
    </ul>
  </div>
</div>

  </div>
</section>

<style>
/* ===== SPLIDE SLIDER ===== */

.features-slider {
  position: relative;
}

/* === FREE / NATURAL layout (≤ perPage slides, no scrolling needed) === */
.features-slider.is-natural .splide__track {
  overflow: visible !important;
}
.features-slider.is-natural .splide__list {
  display: flex !important;
  transform: none !important;
  flex-wrap: nowrap !important;
  justify-content: center !important;
  gap: 30px !important;
  width: 100% !important;
}
.features-slider.is-natural .splide__slide {
  width: auto !important;
  max-width: calc(33.333% - 20px) !important;
  flex: 1 1 0 !important;
  transform: none !important;
  display: flex;
}
/* single slide — full-width card, nicely centered */
.features-slider.is-natural.is-single .splide__slide {
  max-width: 420px !important;
  width: 100% !important;
}

/* === SLIDER layout (more slides than visible) === */
.features-slider:not(.is-natural) .splide__slide {
  /* width set by JS via autoWidth */
  height: auto;
  position: relative;
  border-left: none !important;
  border-right: none !important;
  display: flex;
}

.features-slider .splide__slide::before {
  content: "";
  position: absolute;
  top: 10%;
  bottom: 10%;
  left: -15px;
  width: 1px;
  background-color: var(--wb-color-grey, #d0d0d0);
  opacity: 0.6;
}

.features-slider .splide__slide:first-child::before,
.features-slider.is-natural.is-multi .splide__slide:first-child::before {
  display: none !important;
}

/* hide divider only when there is a single card */
.features-slider.is-natural.is-single .splide__slide::before {
  display: none !important;
}

/* show divider between cards in natural multi-card layout */
.features-slider.is-natural.is-multi .splide__slide::before {
  display: block !important;
}

/* Arrows */
.features-slider .splide__arrows {
  position: absolute;
  top: -70px;
  right: 0;
  display: flex;
  gap: 12px;
  direction: ltr !important;
}

.features-slider .splide__arrow {
  position: static !important;
  transform: none !important;
  width: 30px;
  height: 30px;
  border: 1px solid #d9d9d9;
  background: #fff;

  opacity: 1;
  box-shadow: none;
}

.features-slider .splide__arrow:hover {
  background: #f5f5f5;
}

/* Reset all theme transforms */
.features-slider .splide__arrow svg {
  fill: #0c4168;
  width: 12px;
  height: 12px;
  transform: none !important;
}

/* Force correct directions */
.features-slider .splide__arrow--prev svg {
  transform: rotate(180deg) !important;
}

.features-slider .splide__arrow--next svg {
  transform: rotate(0deg) !important;
}

.features-slider .splide__pagination {
  margin-top: 30px;
}

/* ===== FEATURE CARDS ===== */

.features-grid__card {
  background: var(--fg-card-bg);
  padding: var(--fg-card-padding);
  height: 100%;
  width: 100%;
  display: flex;
  flex-direction: row;
  align-items: center;

  gap: 10px;
  margin-bottom: 10px;
}

.features-grid__img-wrap {
  width: 75px;
  height: 75px;
  min-width: 75px;
  max-width: 75px;
  flex-shrink: 0;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.features-grid__img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.features-grid__content-wrap {
  display: flex;
  flex-direction: column;
  justify-content: center;
  flex: 1;
  min-width: 0;
}

.features-grid__heading {
  color: var(--fg-text);
  font-size: clamp(20px, 2vw, 22px);
  font-weight: 700;
  line-height: 1.25;
  margin: 0 0 4px 0;
  text-align: left;
  text-transform: uppercase;
  letter-spacing: 0.02em;
}

.features-grid__subheading {
  color: var(--fg-text);
  font-size: 13.5px;
  font-weight: 500;
  line-height: 1.3;
  margin: 0 0 8px 0;
  text-align: left;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  opacity: 0.9;
}

.features-grid__desc {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.features-grid__desc p {
  color: var(--fg-desc-color, #4a4a4a);
  font-size: 12px;
  font-weight: var(--fg-desc-weight, 400);
  line-height: 17px;
  margin: 0;
  text-align: left;
}

/* ===== SECTION ===== */

#features-grid-{{ section.id }} {
  background-color: var(--fg-bg);
  padding-top: var(--fg-section-padding-top);
  padding-bottom: var(--fg-section-padding-bottom);
}

#features-grid-{{ section.id }} .features-grid__container {
  max-width: {{ section.settings.container_width }}px;
  margin: 0 auto;
  padding: 0 24px;
}

#features-grid-{{ section.id }} .features-grid__header {
  text-align: {{ section.settings.header_align }};
  margin-bottom: {{ section.settings.header_gap }}px;
}

#features-grid-{{ section.id }} .features-grid__section-title {
  color: var(--fg-text);
  font-size: var(--fg-section-title-size);
  font-weight: var(--fg-section-title-weight);
  margin: 0 0 12px;
  line-height: 1.2;
}

#features-grid-{{ section.id }} .features-grid__section-sub {
  color: var(--fg-desc-color);
  font-size: var(--fg-section-sub-size);
  font-weight: var(--fg-section-sub-weight);
  margin: 0;
  max-width: 600px;
}

/* ===== MOBILE ===== */

@media (max-width: 768px) {
  #features-grid-{{ section.id }} .features-grid__section-title {
    font-size: var(--fg-section-title-size-mobile);
  }

  #features-grid-{{ section.id }} .features-grid__section-sub {
    font-size: var(--fg-section-sub-size-mobile);
  }

  .features-grid__card {
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;

  }

  .features-grid__heading {
    font-size: var(--fg-heading-size-mobile, 18px);
  }

  .features-grid__subheading {
    font-size: 12px;
  }

  .features-grid__desc p {
    font-size: var(--fg-desc-size-mobile, 13.5px);
    line-height: 17px;
  }

  .features-slider .splide__arrow svg {
    height: 12px;
    width: 12px;
  }

  #features-grid-{{ section.id }} {
    padding-top: 30px;
    padding-bottom: 30px;
  }

  .features-grid__img-wrap {
    width: 70px;
    height: 70px;
    min-width: 70px;
    max-width: 70px;
  }

  .features-slider .splide__arrows {
    top: -10px;
  }

  .features-slider .splide__arrow {
    width: 25px;
    height: 25px;
  }
}
</style>




<script>
document.addEventListener('DOMContentLoaded', function () {
  var splideEl = document.querySelector('#features-slider-{{ section.id }}');
  if (!splideEl) return;

  var totalSlides = splideEl.querySelectorAll('.splide__slide').length;

  /* --- Breakpoint thresholds matching Splide --- */
  function getPerPage() {
    var w = window.innerWidth;
    if (w <= 480) return 1;
    if (w <= 768) return 2;
    return 3;  /* desktop: show 3, peek 4th */
  }

  /* --- Set slide widths for autoWidth mode (slider mode) --- */
  function setSlideWidths() {
    var perPage = getPerPage();
    var gap = 30;
    var trackW = splideEl.querySelector('.splide__track').offsetWidth;
    /* Show perPage full slides + ~20% of next one */
    var peekFraction = 0.20;
    var slideW = Math.floor((trackW - gap * (perPage - 1 + peekFraction)) / (perPage + peekFraction));
    splideEl.querySelectorAll('.splide__slide').forEach(function (sl) {
      sl.style.width = slideW + 'px';
    });
  }

  /* --- Switch between natural (flex) and slider mode --- */
  function applyLayout() {
    var perPage = getPerPage();
    var needsSlider = totalSlides > perPage;

    if (!needsSlider) {
      /* Natural / free layout — no stretching */
      splideEl.classList.add('is-natural');
      splideEl.classList.toggle('is-single', totalSlides === 1);
      splideEl.classList.toggle('is-multi', totalSlides > 1);
      /* Reset any inline widths */
      splideEl.querySelectorAll('.splide__slide').forEach(function (sl) {
        sl.style.width = '';
      });
    } else {
      splideEl.classList.remove('is-natural', 'is-single', 'is-multi');
      setSlideWidths();
    }

    /* Show/hide arrows */
    var arrowsEl = splideEl.querySelector('.splide__arrows');
    if (arrowsEl) {
      arrowsEl.style.display = needsSlider ? '' : 'none';
    }
  }

  var splide = new Splide('#features-slider-{{ section.id }}', {
    type     : 'slide',
    autoWidth: true,       /* respect our manually set widths */
    perMove  : 1,
    gap      : '30px',
    arrows   : true,
    pagination: false,
    rewind   : true,
    drag     : totalSlides > 1
  });

  splide.on('mounted', applyLayout);
  splide.on('resize',  applyLayout);
  splide.mount();
});
</script>

{%- endif -%}

{% schema %}
{
  "name": "Features Grid",
  "tag": "section",
  "class": "features-grid-section",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "section_heading",
      "label": "Section Heading",
      "default": "Why Choose Us"
    },
    {
      "type": "textarea",
      "id": "section_subheading",
      "label": "Section Subheading"
    },
    {
      "type": "range",
      "id": "section_heading_size",
      "label": "Section Heading Size (px)",
      "min": 20,
      "max": 72,
      "step": 2,
      "default": 40
    },
    {
      "type": "range",
      "id": "section_heading_size_mobile",
      "label": "Section Heading Size Mobile (px)",
      "min": 16,
      "max": 60,
      "step": 1,
      "default": 26
    },
    {
      "type": "select",
      "id": "section_heading_weight",
      "label": "Section Heading Font Weight",
      "default": "700",
      "options": [
        { "value": "400", "label": "400" },
        { "value": "500", "label": "500" },
        { "value": "600", "label": "600" },
        { "value": "700", "label": "700" },
        { "value": "800", "label": "800" }
      ]
    },
    {
      "type": "range",
      "id": "section_subheading_size_desktop",
      "label": "Section Subheading Size Desktop (px)",
      "min": 10,
      "max": 32,
      "step": 1,
      "default": 15
    },
    {
      "type": "range",
      "id": "section_subheading_size_mobile",
      "label": "Section Subheading Size Mobile (px)",
      "min": 10,
      "max": 28,
      "step": 1,
      "default": 14
    },
    {
      "type": "select",
      "id": "section_subheading_weight",
      "label": "Section Subheading Font Weight",
      "default": "400",
      "options": [
        { "value": "400", "label": "400" },
        { "value": "500", "label": "500" },
        { "value": "600", "label": "600" },
        { "value": "700", "label": "700" },
        { "value": "800", "label": "800" }
