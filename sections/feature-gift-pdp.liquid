      "step": 1,
      "default": 22
    },
    {
      "type": "range",
      "id": "card_heading_font_size_desktop",
      "label": "Card Heading Size Desktop (px)",
      "min": 14,
      "max": 40,
      "step": 1,
      "default": 22
    },
    {
      "type": "range",
      "id": "card_heading_font_size_mobile",
      "label": "Card Heading Size Mobile (px)",
      "min": 12,
      "max": 32,
      "step": 1,
      "default": 18
    },
    {
      "type": "select",
      "id": "card_heading_font_weight",
      "label": "Card Heading Font Weight",
      "default": "700",
      "options": [
        { "value": "400", "label": "400" },
        { "value": "500", "label": "500" },
        { "value": "600", "label": "600" },
        { "value": "700", "label": "700" },
        { "value": "800", "label": "800" }
      ]
    },
    {
      "type": "range",
      "id": "desc_font_size",
