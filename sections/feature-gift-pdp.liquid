    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#c9d4d4"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Heading Color",
      "default": "#1a1a2e"
    },
    {
      "type": "color",
      "id": "desc_color",
      "label": "Description Color",
      "default": "#3a3a4a"
    },
    {
      "type": "header",
