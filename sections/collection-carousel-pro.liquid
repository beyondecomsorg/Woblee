<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flickity@2/dist/flickity.min.css">
<script src="https://cdn.jsdelivr.net/npm/flickity@2/dist/flickity.pkgd.min.js" defer></script>

<section
  class="collection-carousel-pro"
  id="collection-carousel-{{ section.id }}"
  style="
    --section-bg: {{ section.settings.background_color }};
    --small-heading-color: {{ section.settings.small_heading_color }};
    --main-heading-color: {{ section.settings.main_heading_color }};
    --description-color: {{ section.settings.description_color }};
    --shop-all-btn-text-color: {{ section.settings.shop_all_button_text_color }};
    --shop-all-btn-bg-color: {{ section.settings.shop_all_button_background_color }};
    --shop-all-btn-border-color: {{ section.settings.shop_all_button_border_color }};
    --card-title-color: {{ section.settings.card_title_color }};
    --overlay-color: {{ section.settings.overlay_color }};
    --overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --card-radius: {{ section.settings.card_radius }}px;
    --arrow-bg: {{ section.settings.arrow_bg }};
    --arrow-color: {{ section.settings.arrow_color }};
    --arrow-size: {{ section.settings.arrow_size }}px;
    --content-width: {{ section.settings.content_width }}%;
    --card-gap: {{ section.settings.card_gap }}px;
    --padding-top: {{ section.settings.padding_top }}px;
    --padding-bottom: {{ section.settings.padding_bottom }}px;
    --padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --card-height-desktop: {{ section.settings.card_height_desktop }}px;
    --card-height-mobile: {{ section.settings.card_height_mobile }}px;
    --shop-all-btn-width-desktop: {{ section.settings.shop_all_button_width_desktop }}px;
    --shop-all-btn-height-desktop: {{ section.settings.shop_all_button_height_desktop }}px;
    --shop-all-btn-width-mobile: {{ section.settings.shop_all_button_width_mobile }}px;
    --shop-all-btn-height-mobile: {{ section.settings.shop_all_button_height_mobile }}px;
    --shop-all-btn-font-size-desktop: {{ section.settings.shop_all_button_font_size_desktop }}px;
    --shop-all-btn-font-size-mobile: {{ section.settings.shop_all_button_font_size_mobile }}px;
    --shop-all-btn-font-weight: {{ section.settings.shop_all_button_font_weight }};
    --shop-all-btn-radius: {{ section.settings.shop_all_button_border_radius }}px;
    --shop-all-btn-border-width: {{ section.settings.shop_all_button_border_width }}px;
    --shop-all-btn-margin-top: {{ section.settings.shop_all_button_margin_top }}px;
    --shop-all-btn-margin-bottom: {{ section.settings.shop_all_button_margin_bottom }}px;
  "
>
  <div class="collection-carousel-pro__container">

    <div class="collection-carousel-pro__content">
      {% if section.settings.small_heading != blank %}
        <div class="collection-carousel-pro__eyebrow">{{ section.settings.small_heading }}</div>
      {% endif %}
      {% if section.settings.main_heading != blank %}
        <h2 class="collection-carousel-pro__heading">{{ section.settings.main_heading }}</h2>
      {% endif %}
      {% if section.settings.description != blank %}
        <div class="collection-carousel-pro__description">{{ section.settings.description }}</div>
      {% endif %}
      {% if section.settings.enable_shop_all_button %}
        <a class="collection-carousel-pro__shop-all-btn collection-carousel-pro__shop-all-btn--desktop"
          href="{% if section.settings.shop_all_button_link != blank %}{{ section.settings.shop_all_button_link }}{% else %}#{% endif %}">
          {{ section.settings.shop_all_button_text }}
        </a>
      {% endif %}
    </div>

    <div class="collection-carousel-pro__slider-wrapper">
      <div class="collection-carousel-flickity" id="flickity-{{ section.id }}">
        {% for block in section.blocks %}
          {% if block.type == 'card' %}
            <div class="collection-carousel-pro__slide" {{ block.shopify_attributes }}>
              <div class="collection-carousel-pro__card">
                {% if block.settings.image != blank %}
                  {% if forloop.index0 < 3 %}
                    {{ block.settings.image | image_url: width: 1200 | image_tag:
                      loading: 'eager',
                      fetchpriority: 'high',
                      class: 'collection-carousel-pro__image',
                      widths: '400, 600, 800, 1200',
                      sizes: '(max-width: 767px) 90vw, 50vw'
                    }}
                  {% else %}
                    {{ block.settings.image | image_url: width: 1200 | image_tag:
                      loading: 'lazy',
                      class: 'collection-carousel-pro__image',
                      widths: '400, 600, 800, 1200',
                      sizes: '(max-width: 767px) 90vw, 50vw'
                    }}
                  {% endif %}
                {% endif %}
                <div class="collection-carousel-pro__overlay"></div>
                {% if block.settings.title != blank %}
                  <div class="collection-carousel-pro__title">{{ block.settings.title }}</div>
                {% endif %}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    {% if section.settings.enable_shop_all_button %}
      <a href="{% if section.settings.shop_all_button_link != blank %}{{ section.settings.shop_all_button_link }}{% else %}#{% endif %}"
        class="collection-carousel-pro__shop-all-btn collection-carousel-pro__shop-all-btn--mobile">
        {{ section.settings.shop_all_button_text }}
      </a>
    {% endif %}

  </div>
</section>

{% style %}

.collection-carousel-pro {
  background: var(--section-bg);
  padding-top: var(--padding-top);
  padding-bottom: var(--padding-bottom);
}

.collection-carousel-pro__container {
  max-width: 1800px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  padding-top: 15px;
  padding-bottom: 15px;
  gap: 40px;
  overflow: hidden;
}

.collection-carousel-pro__content {
  width: var(--content-width);
  flex-shrink: 0;
  padding-left: 60px;
}

.collection-carousel-pro__eyebrow {
  color: var(--small-heading-color);
  font-family: {{ section.settings.section_font.family }}, {{ section.settings.section_font.fallback_families }};
  font-size: {{ section.settings.small_heading_size }}px;
  font-weight: {{ section.settings.small_heading_weight }};
  text-transform: uppercase;
  margin-bottom: 20px;
}

.collection-carousel-pro__heading {
  color: var(--main-heading-color);
  font-family: {{ section.settings.section_font.family }}, {{ section.settings.section_font.fallback_families }};
  font-size: {{ section.settings.main_heading_size }}px;
  font-weight: {{ section.settings.main_heading_weight }};
  line-height: 1;
  word-break: normal;
  text-transform: uppercase;
  margin: 0 0 24px;
}

.collection-carousel-pro__description {
  color: var(--description-color);
  font-family: {{ section.settings.section_font.family }}, {{ section.settings.section_font.fallback_families }};
  font-size: {{ section.settings.description_size }}px;
  font-weight: {{ section.settings.description_weight }};
  line-height: 1.8;
  max-width: 450px;
}

.collection-carousel-pro__shop-all-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  max-width: 100%;
  padding: 0 16px;
  border: var(--shop-all-btn-border-width) solid var(--shop-all-btn-border-color);
  border-radius: var(--shop-all-btn-radius);
  background: var(--shop-all-btn-bg-color);
  color: var(--shop-all-btn-text-color);
  font-family: {{ section.settings.section_font.family }}, {{ section.settings.section_font.fallback_families }};
  font-weight: var(--shop-all-btn-font-weight);
  line-height: 1;
  text-transform: uppercase;
  text-decoration: none;
  text-align: center;
  box-sizing: border-box;
  cursor: pointer;
}

.collection-carousel-pro__shop-all-btn:hover { opacity: 0.9; }

.collection-carousel-pro__shop-all-btn--desktop {
  width: var(--shop-all-btn-width-desktop);
  height: var(--shop-all-btn-height-desktop);
  font-size: var(--shop-all-btn-font-size-desktop);
  margin-top: var(--shop-all-btn-margin-top);
  margin-bottom: var(--shop-all-btn-margin-bottom);
}

.collection-carousel-pro__shop-all-btn--mobile {
  display: none;
}

.collection-carousel-pro__slider-wrapper {
  flex: 1;
  min-width: 0;
}

/* Flickity base */
.collection-carousel-flickity {
  outline: none;
}

.collection-carousel-pro__slide {
  width: 40%;
  margin-right: var(--card-gap);
}

.collection-carousel-pro__card {
  position: relative;
  width: 100%;
  height: var(--card-height-desktop);
  border-radius: var(--card-radius);
  overflow: hidden;
  cursor: pointer;
  -webkit-tap-highlight-color: transparent;
  transform: translateZ(0);
  -webkit-transform: translateZ(0);
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
}

.collection-carousel-pro__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  pointer-events: none;
  -webkit-user-drag: none;
  transform: translateZ(0);
  -webkit-transform: translateZ(0);
  transition: transform 0.5s ease;
  will-change: transform;
}

.collection-carousel-pro__card:hover .collection-carousel-pro__image {
  transform: scale(1.05);
}

.collection-carousel-pro__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(        to top,        rgba(12, 65, 104, 0.25) 0%,        rgba(12, 65, 104, -2.85) 25%,        transparent 60%    );
  z-index: 1;
  pointer-events: none;
}

.collection-carousel-pro__title {
  position: absolute;
  left: 30px;
  bottom: 30px;
  z-index: 2;
  color: var(--card-title-color);
  font-family: {{ section.settings.section_font.family }}, {{ section.settings.section_font.fallback_families }};
  font-size: {{ section.settings.card_title_size }}px;
  font-weight: {{ section.settings.card_title_weight }};
  text-transform: uppercase;
  line-height: 1;
  pointer-events: none;
}

/* Flickity arrow overrides */
.collection-carousel-flickity .flickity-button {
  background: var(--arrow-bg);
  width: var(--arrow-size);
  height: var(--arrow-size);
}

.collection-carousel-flickity .flickity-button-icon {
  fill: var(--arrow-color);
}

.collection-carousel-flickity .flickity-button:focus {
  box-shadow: none;
}

.collection-carousel-flickity .flickity-page-dots {
  bottom: -28px;
}

/* ── MOBILE ── */
@media screen and (max-width: 767px) {

  .collection-carousel-pro {
    padding-top: var(--padding-top-mobile);
    padding-bottom: var(--padding-bottom-mobile);
  }

  .collection-carousel-pro__container {
    flex-direction: column;
    gap: 24px;
    overflow: visible;
    padding-top: 15px;
    padding-bottom: 15px;
  }

  .collection-carousel-pro__content {
    width: 100%;
    padding: 0 20px;
    text-align: center;
  }

  .collection-carousel-pro__description {
    margin: 0 auto;
    max-width: 100%;
    font-size: {{ section.settings.description_size_mobile }}px;
  }

  .collection-carousel-pro__eyebrow {
    font-size: {{ section.settings.small_heading_size_mobile }}px;
  }

  .collection-carousel-pro__heading {
    font-size: {{ section.settings.main_heading_size_mobile }}px;
    margin-bottom: 15px;
  }

  .collection-carousel-pro__shop-all-btn--desktop {
    display: none !important;
  }

  .collection-carousel-pro__shop-all-btn--mobile {
    display: inline-flex;
    width: var(--shop-all-btn-width-mobile);
    height: var(--shop-all-btn-height-mobile);
    font-size: var(--shop-all-btn-font-size-mobile);
    margin: var(--shop-all-btn-margin-top) auto var(--shop-all-btn-margin-bottom);
  }

  .collection-carousel-pro__slider-wrapper {
    width: 100%;
    padding-left: 15px;
  }

  .collection-carousel-pro__slide {
    width: 80%;
    margin-right: 12px;
  }

  .collection-carousel-pro__card {
    height: var(--card-height-mobile);
  }

  .collection-carousel-pro__title {
    font-size: 22px;
    left: 20px;
    bottom: 20px;
  }

  .collection-carousel-flickity .flickity-page-dots {
    display: flex;
  }
}
.flickity-prev-next-button .flickity-button-icon{
  height: 18px;
  width: 18px;
}

{% endstyle %}
<script>
(function () {
  function initCarousel() {
    var section = document.getElementById('collection-carousel-{{ section.id }}');
    if (!section) return;

    var carousel = section.querySelector('.collection-carousel-flickity');
    if (!carousel) return;

    if (typeof Flickity === 'undefined') {
      setTimeout(initCarousel, 100);
      return;
    }

    if (carousel._flickity) return;

    new Flickity(carousel, {
      cellAlign: 'left',
      contain: false,
      wrapAround: true,
      groupCells: false,
      autoPlay: 3000,
      pageDots: false,
      prevNextButtons: true,
      draggable: true,
      freeScroll: false,
      friction: 0.28,
      selectedAttraction: 0.025,
      imagesLoaded: true,
      lazyLoad: 2,
      adaptiveHeight: false
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCarousel);
  } else {
    initCarousel();
  }
})();
</script>

