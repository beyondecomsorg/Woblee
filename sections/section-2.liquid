{% comment %}
  ============================================================
  ABOUT US — Polaroid Fan Layout  |  Mime360
  ============================================================
{% endcomment %}

{%- liquid
  assign bg_color = section.settings.background_color
  assign heading   = section.settings.heading
  assign body_text = section.settings.body_text
  assign cta_text  = section.settings.cta_text
  assign cta_url   = section.settings.cta_url
  assign accent    = section.settings.accent_color
  assign card_blocks = section.blocks | where: 'type', 'card'
-%}

<section
  class="wau-section"
  id="wau-{{ section.id }}"
  style="
    --wau-bg: {{ section.settings.background_color }};
    --wau-accent: {{ section.settings.accent_color }};
    --wau-blob-color: {{ section.settings.blob_color }};

    --wau-heading-color: {{ section.settings.heading_color }};
    --wau-body-color: {{ section.settings.body_color }};

    --wau-button-bg: {{ section.settings.button_bg }};
    --wau-button-text: {{ section.settings.button_text }};
    --wau-button-hover-bg: {{ section.settings.button_hover_bg }};
    --wau-button-hover-text: {{ section.settings.button_hover_text }};

    --wau-stats-number-color: {{ section.settings.stats_number_color }};
    --wau-stats-label-color: {{ section.settings.stats_label_color }};
    --wau-stats-number-size: {{ section.settings.stats_number_size }}px;
    --wau-stats-number-size-mobile: {{ section.settings.stats_number_size_mobile }}px;
    --wau-stats-number-weight: {{ section.settings.stats_number_weight }};
    --wau-stats-label-size: {{ section.settings.stats_label_size }}px;
    --wau-stats-label-size-mobile: {{ section.settings.stats_label_size_mobile }}px;
    --wau-stats-label-weight: {{ section.settings.stats_label_weight }};

    --wau-heading-size: {{ section.settings.heading_size }}px;
    --wau-heading-size-mobile: {{ section.settings.heading_size_mobile }}px;
    --wau-heading-weight: {{ section.settings.heading_weight }};

    --wau-body-size: {{ section.settings.body_size }}px;
    --wau-body-size-mobile: {{ section.settings.body_size_mobile }}px;
    --wau-body-weight: {{ section.settings.body_weight }};

    --wau-button-size: {{ section.settings.button_font_size }}px;
    --wau-button-size-mobile: {{ section.settings.button_font_size_mobile }}px;
    --wau-button-weight: {{ section.settings.button_font_weight }};
    --wau-button-width: {{ section.settings.button_width_desktop }}px;
    --wau-button-height: {{ section.settings.button_height_desktop }}px;
    --wau-button-width-mobile: {{ section.settings.button_width_mobile }}px;
    --wau-button-height-mobile: {{ section.settings.button_height_mobile }}px;

    --wau-pt: {{ section.settings.padding_top }}px;
    --wau-pb: {{ section.settings.padding_bottom }}px;
  "
>
  <!-- BG image layer -->
  {%- if section.settings.bg_image != blank -%}
    <div class="wau-bg-img" style="background-image: url('{{ section.settings.bg_image | image_url: width: 1600 }}');"></div>
  {%- endif -%}
  <div class="wau-bg-overlay"></div>

  <div class="wau-inner">

    <!-- ═══ LEFT ═══ -->
<div class="wau-left">
  {% if section.settings.heading != blank %}
    <h2 class="wau-heading">
      {{ section.settings.heading }}
    </h2>
  {% endif %}

  {% if section.settings.body_text != blank %}
    <div class="wau-body ccc">
      {{ section.settings.body_text }}
    </div>
  {% endif %}

  {% if section.settings.cta_text != blank %}
    <a href="{{ section.settings.cta_url }}" class="wau-cta">
      <span>{{ section.settings.cta_text }}</span>

      <svg width="18" height="18" viewBox="0 0 14 14" fill="none">
        <path
          d="M1 7H13M13 7L7 1M13 7L7 13"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    </a>
  {% endif %}

  <div class="wau-stats">
    {% for block in section.blocks %}
      {% if block.type == 'stat' %}
        <div class="wau-stat-pill" {{ block.shopify_attributes }}>
          <strong>{{ block.settings.stat_value }}</strong>
          <span>{{ block.settings.stat_label }}</span>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

    <!-- ═══ RIGHT — Polaroid Fan ═══ -->
<div class="wau-right">
  <div class="wau-fan-wrap">

    {% for block in section.blocks %}
      {% if block.type == 'card' %}
        <div class="wau-pcard wau-pcard--{{ forloop.index0 }}" {{ block.shopify_attributes }}>

          <div class="wau-pcard__inner">

            {% if block.settings.card_image != blank %}
              {{
                block.settings.card_image
                | image_url: width: 700
                | image_tag:
                  loading: 'lazy',
                  class: 'wau-pcard__img'
              }}
            {% endif %}

            {% if block.settings.card_label != blank %}
              <div class="wau-pcard__caption">
                {{ block.settings.card_label }}
              </div>
            {% endif %}

          </div>

        </div>
      {% endif %}
    {% endfor %}

    <div class="wau-blob wau-blob--1"></div>
    <div class="wau-blob wau-blob--2"></div>

  </div>
</div>
  </div><!-- /inner -->

  <!-- ═══ MARQUEE STRIP ═══ -->


</section>

<!-- ════════════════════════════
  CSS
════════════════════════════ -->
<style>
#wau-{{ section.id }} *, #wau-{{ section.id }} *::before, #wau-{{ section.id }} *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

/* ── Shell ── */
.wau-section {
  position: relative;
  overflow: hidden;
  padding-top: var(--wau-pt);
  padding-bottom: var(--wau-pb);
  background: var(--wau-bg);
}

.wau-bg-img {
  position: absolute;
  inset: 0;
  background-size: cover;
  background-position: center;
  z-index: 0;
}

.wau-bg-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(100deg, rgba(12,65,104,0.92) 0%, rgba(12,65,104,0.70) 55%, rgba(12,65,104,0.30) 100%);
  z-index: 1;
}

/* ── Inner grid ── */
.wau-inner {
  position: relative;
  z-index: 2;
  max-width: 100%;
  margin: 0 auto;
  padding: 0 60px var(--wau-pb, 80px);
  display: grid;
  grid-template-columns: 44% 1fr;
  gap: 0;
  align-items: center;
  min-height: 500px;
}

/* ══ LEFT ══════════════════════════════ */
.wau-left {
    gap: 10px;
  color: var(--wb-color-white);
  padding-right: 40px;
      width: 82%;
  margin: auto !important;
    display: flex;
    flex-direction: column;
    justify-content: center;
}

.wau-heading {
  font-family: {{ section.settings.section_font.family }}, {{ section.settings.section_font.fallback_families }};
  font-size: var(--wau-heading-size);
  font-weight: var(--wau-heading-weight);
  color: var(--wau-heading-color);
  line-height: 1.1;
  text-transform: uppercase;
  margin-bottom: 28px;
}

.wau-section.wau-visible .wau-heading {
  opacity: 1;
  transform: translateX(0);
}

.wau-body {
  font-family: {{ section.settings.section_font.family }}, {{ section.settings.section_font.fallback_families }};
  font-size: var(--wau-body-size);
  font-weight: var(--wau-body-weight);
  color: var(--wau-body-color);
  line-height: 1.7;
  max-width: 450px;
  margin-bottom: 36px;
}

.wau-section.wau-visible .wau-body {
  opacity: 1;
  transform: translateX(0);
}

/* CTA */
.wau-cta:hover {
  background: var(--wau-button-hover-bg);
  color: var(--wau-button-hover-text);
}
.wau-stat-pill strong,
.wau-stat-pill span {
  font-family: Helvetica;
}
.wau-pcard__caption {
  font-family: Helvetica;
}
.wau-cta {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  text-decoration: none;

  font-family: Helvetica;
  font-size: var(--wau-button-size);
  font-weight: var(--wau-button-weight);
  width: var(--wau-button-width);
  min-width: var(--wau-button-width);
  height: var(--wau-button-height);
  min-height: var(--wau-button-height);
  background: var(--wau-button-bg);
  color: var(--wau-button-text);
  padding: 0 14px;
  transition: all .3s ease;
  box-sizing: border-box;
}

.wau-cta::after {
  /* content: ''; */
  position: absolute;
  inset: 0;
  background: rgba(255,255,255,0.18);
  transform: translateX(-100%);
  transition: transform 0.3s ease;
}

.wau-cta:hover::after {
  transform: translateX(0);
}


.wau-section.wau-visible .wau-cta {
  opacity: 1;
  transform: translateY(0);
}

/* Stats */
.wau-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-top: 36px;
  opacity: 0;
  transform: translateY(16px);
  transition: opacity 0.8s ease 0.38s, transform 0.8s ease 0.38s;
}

.wau-section.wau-visible .wau-stats {
  opacity: 1;
  transform: translateY(0);
}

.wau-stat-pill {
  background: rgba(255,255,255,0.07);
  border: 1px solid rgba(255,255,255,0.13);

  padding: 14px 20px !important;
  display: flex;
  flex-direction: column;
  gap: 3px;
  backdrop-filter: blur(10px);
  transition: background 0.25s, border-color 0.25s;
}

.wau-stat-pill:hover {
  background: rgba(255,255,255,0.13);
  border-color: var(--wb-color-lime, #21F010);
}

.wau-stat-pill strong {
  font-family: var(--wb-font-heading, sans-serif);
  font-size: var(--wau-stats-number-size);
  font-weight: var(--wau-stats-number-weight);
  color: var(--wau-accent);
  line-height: 1;
}

.wau-stat-pill span {
  font-size: var(--wau-stats-label-size);
  font-weight: var(--wau-stats-label-weight);
  letter-spacing: var(--wb-letter-wide, 0.1em);
  text-transform: uppercase;
  color: rgba(255,255,255,0.5);
  font-family: Helvetica;
}

/* ══ RIGHT — Fan cards ══════════════════ */
.wau-right {
  position: relative;
  z-index: 2;
}

.wau-fan-wrap {
  position: relative;
  width: 50%;
  height: 520px;
  margin: auto !important;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Base polaroid card */
.wau-pcard {
  position: absolute;
  width: 220px;
  background: var(--wb-color-white, #fff);
  padding: 10px 10px 36px;
  box-shadow: var(--wb-shadow-md, 0 24px 60px rgba(0,0,0,0.38));
  cursor: pointer;
  transform-origin: center bottom;
  will-change: transform;
  transition: box-shadow 0.35s ease;
}

.wau-pcard:hover {
  box-shadow: 0 36px 80px rgba(0,0,0,0.55);
  z-index: 20 !important;
}

/* Fan positions — staggered like scattered photos */
.wau-pcard--0 {
  left: 50px;
  top: 50px;
  z-index: 10;
  --base-rot: -12deg;
}

.wau-pcard--1 {
  left: 160px;
  top: 20px;
  z-index: 11;
  --base-rot: 2deg;
}

.wau-pcard--2 {
  left: 270px;
  top: 60px;
  z-index: 12;
  --base-rot: 14deg;
}

.wau-pcard__inner {
  width: 100%;
  overflow: hidden;

}

.wau-pcard__img {
  width: 100%;
  aspect-ratio: 3/4;
  object-fit: cover;
  display: block;
  transition: transform 0.5s ease;
}

.wau-pcard:hover .wau-pcard__img {
  transform: scale(1.04);
}

.wau-pcard__img--ph {
  opacity: 0.25;
  background: #aac;
}

.wau-pcard__caption {
  text-align: center;
  margin-top: 10px;
  font-family: var(--wb-font-body, sans-serif);
  font-size: 9px;
  font-weight: var(--wb-fw-bold, 700);
  letter-spacing: var(--wb-letter-wide, 0.09em);
  text-transform: uppercase;
  color: var(--wb-color-blue, #333);
}

/* Blobs */
.wau-blob {
  position: absolute;
  filter: blur(70px);
  pointer-events: none;
  z-index: 0;
}

.wau-blob--1 {
  width: 280px;
  height: 280px;
background: var(--wau-accent);
  opacity: 0.07;
  top: -20px;
  right: -40px;
  animation: wau-pulse 7s ease-in-out infinite alternate;
}

.wau-blob--2 {
  width: 220px;
  height: 220px;
  background: #851828;
  opacity: 0.1;
  bottom: 30px;
  left: 10px;
  animation: wau-pulse 9s ease-in-out infinite alternate-reverse;
}

@keyframes wau-pulse {
  from { transform: scale(1); }
  to { transform: scale(1.3); }
}

/* ══ MARQUEE ══════════════════════════ */
.wau-marquee-wrap {
  position: relative;
  z-index: 2;
  overflow: hidden;
  border-top: 1px solid rgba(255,255,255,0.1);
  background: rgba(0,0,0,0.2);
  padding: 17px 0;
  margin-top: 0;
  -webkit-mask-image: linear-gradient(to right, transparent 0%, #000 6%, #000 94%, transparent 100%);
  mask-image: linear-gradient(to right, transparent 0%, #000 6%, #000 94%, transparent 100%);
}

.wau-marquee-track {
  display: flex;
  white-space: nowrap;
  animation: wau-scroll 32s linear infinite;
  will-change: transform;
}

.wau-marquee-wrap:hover .wau-marquee-track {
  animation-play-state: paused;
}

@keyframes wau-scroll {
  from { transform: translateX(0); }
  to { transform: translateX(-25%); }
}

.wau-ticker-item {
  display: inline-flex;
  align-items: center;
  gap: 14px;
  padding: 0 26px;
  font-family: var(--wb-font-heading, 'Bebas Neue', 'Arial Black', sans-serif);
  font-size: var(--wb-h5, clamp(15px, 1.6vw, 21px));
  font-weight: var(--wb-fw-extrabold, 900);
  letter-spacing: var(--wb-letter-wide, 0.16em);
  text-transform: uppercase;
  color: rgba(255,255,255,0.88);
}

.wau-ticker-star {
  color: var(--wb-color-lime, #21F010);
  font-size: 0.5em;
  animation: wau-spin 5s linear infinite;
  display: inline-block;
}

@keyframes wau-spin {
  to { transform: rotate(360deg); }
}


  .shopify-section.wau-section-wrapper{
    padding-top: {{ section.settings.padding_desktop-top }}px;
  padding-bottom: {{ section.settings.padding_desktop-bottom }}px;
  }

/* ══ RESPONSIVE ═══════════════════════ */
@media (max-width: 900px) {
  .wau-inner {
    grid-template-columns: 1fr;
    padding: 0 24px 60px;
    gap: 52px;
    min-height: unset;
  }


  .shopify-section.wau-section-wrapper{
    padding-top: {{ section.settings.padding_top_mobile }}px;
  padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }
  {% comment %} .wau-section {
  padding-top: var(--wau-pt-mobile);
  padding-bottom: var(--wau-pb-mobile);
} {% endcomment %}
  .wau-stat-pill span{
  font-size: 10px;
}


  .wau-left {
    padding-right: 0;
  }

  .wau-fan-wrap {
    height: 380px;
    width: 77% !important;
  }

  .wau-pcard {
    width: 165px;
  }

  .wau-pcard--0 {
    left: 20px;
    top: 40px;
  }

  .wau-pcard--1 {
    left: 110px;
    top: 15px;
  }

  .wau-pcard--2 {
    left: 200px;
    top: 50px;
  }
}

@media (max-width: 768px) {
  .wau-heading {
    font-size: var(--wau-heading-size-mobile) !important;
  }

  .wau-body {
    font-size: var(--wau-body-size-mobile);
  }

  .wau-stat-pill strong {
    font-size: var(--wau-stats-number-size-mobile);
  }

  .wau-stat-pill span {
    font-size: var(--wau-stats-label-size-mobile);
  }

  .wau-cta {
    width: var(--wau-button-width-mobile);
    min-width: var(--wau-button-width-mobile);
    height: var(--wau-button-height-mobile);
    min-height: var(--wau-button-height-mobile);
    font-size: var(--wau-button-size-mobile);
    padding: 0 8px;
    gap: 6px;
  }
}

@media (max-width: 480px) {
  .wau-fan-wrap {
    height: 300px;
  }

  .wau-pcard {
    width: 130px;
    padding: 7px 7px 28px;
  }

  .wau-pcard--0 {
    left: 10px;
    top: 30px;
  }

  .wau-pcard--1 {
    left: 82px;
    top: 10px;
  }

  .wau-pcard--2 {
    left: 155px;
    top: 45px;
  }

  .wau-heading {
    font-size: clamp(32px, 9vw, 42px);
    
  }

  .wau-body {
    font-size: 14px;
  }

  .wau-ticker-item {
    font-size: 15px;
  }
}

</style>

<!-- ════════════════════════════
  JAVASCRIPT
════════════════════════════ -->
<script>
(function () {
  const SEC = document.getElementById('wau-{{ section.id }}');
  if (!SEC) return;

  /* 1 — Scroll reveal */
  const io = new IntersectionObserver(([e]) => {
    if (e.isIntersecting) { SEC.classList.add('wau-visible'); io.disconnect(); }
  }, { threshold: 0.12 });
  io.observe(SEC);

  /* 2 — Gentle 3D Y-axis rotate per card, staggered phase */
  const cards = SEC.querySelectorAll('.wau-pcard');
  const DUR = 7.0; // seconds per full cycle
  const MAX_Y = 16; // degrees
  const MAX_X = 5;

  // Read the base static rotation from CSS var
  const baseRots = [-12, 2, 14];

  cards.forEach((card, i) => {
    const phaseOffset = (i / cards.length) * DUR; // stagger 1/3 cycle each
    let startTs = null;
    let isHovered = false;

    card.addEventListener('mouseenter', () => { isHovered = true; });
    card.addEventListener('mouseleave', () => { isHovered = false; });

    function tick(ts) {
      if (!startTs) startTs = ts;
      const elapsed = ((ts - startTs) / 1000) + phaseOffset;
      const angle = (elapsed / DUR) * Math.PI * 2;

      if (!isHovered) {
        const rotY = Math.sin(angle) * MAX_Y;
        const rotX = Math.cos(angle) * MAX_X;
        const baseZ = baseRots[i] || 0;
        card.style.transform = `rotate(${baseZ}deg) perspective(800px) rotateY(${rotY}deg) rotateX(${rotX}deg)`;
      } else {
        // On hover: straighten and lift
        card.style.transform = `rotate(0deg) perspective(800px) rotateY(0deg) rotateX(0deg) translateY(-8px) scale(1.05)`;
      }
      requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  });

  /* 3 — Duplicate ticker for seamless loop */
  const track = document.getElementById('wau-ticker-{{ section.id }}');
  if (track) {
    while (track.scrollWidth < window.innerWidth * 4) {
      track.innerHTML += track.innerHTML;
    }
  }
})();
</script>

