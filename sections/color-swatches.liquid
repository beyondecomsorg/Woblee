{%- style -%}
  :root {
    --swatch-color-jet-black: #0A0A0A;
    --swatch-border-jet-black: solid;
    --swatch-color-pure-white: #FFFFFF;
    --swatch-border-pure-white: solid;
    --swatch-color-off-white: #F2EEE4;
    --swatch-border-off-white: solid;
    --swatch-color-classic-red: #C8102E;
    --swatch-border-classic-red: solid;
    --swatch-color-sky-blue: #87CEEB;
    --swatch-border-sky-blue: solid;
    --swatch-color-teal-blue: #158C93;
    --swatch-border-teal-blue: solid;
    --swatch-color-diesel-blue: #2C3E50;
    --swatch-border-diesel-blue: solid;
    --swatch-color-medieval-blue: #1B3F7A;
    --swatch-border-medieval-blue: solid;
    --swatch-color-director-blue: #1F3A5F;
    --swatch-border-director-blue: solid;
    --swatch-color-air-force-blue: #5D8AA8;
    --swatch-border-air-force-blue: solid;
    --swatch-color-brittany-blue: #3B6FA0;
    --swatch-border-brittany-blue: solid;
    --swatch-color-orchid-purple: #9B59B6;
    --swatch-border-orchid-purple: solid;
    --swatch-color-lilac-purple: #C8A2C8;
    --swatch-border-lilac-purple: solid;
    --swatch-color-berry-purple: #6B2C5F;
    --swatch-border-berry-purple: solid;
    --swatch-color-wine-purple: #5B1A34;
    --swatch-border-wine-purple: solid;
    --swatch-color-fuchsia-pink: #C74375;
    --swatch-border-fuchsia-pink: solid;
    --swatch-color-light-pink: #FFB6C1;
    --swatch-border-light-pink: solid;
    --swatch-color-lime-green: #9ACD32;
    --swatch-border-lime-green: solid;
    --swatch-color-moss-green: #8A9A5B;
    --swatch-border-moss-green: solid;
    --swatch-color-bottle-green: #006A4E;
    --swatch-border-bottle-green: solid;
    --swatch-color-honey-yellow: #E8A33D;
    --swatch-border-honey-yellow: solid;
    --swatch-color-solar-yellow: #FFD700;
    --swatch-border-solar-yellow: solid;
    --swatch-color-burnt-orange: #CC5500;
    --swatch-border-burnt-orange: solid;
    --swatch-color-coral-orange: #FF6F4C;
    --swatch-border-coral-orange: solid;
    --swatch-color-rusty-red: #B7410E;
    --swatch-border-rusty-red: solid;
    --swatch-color-mocha-brown: #6F4E37;
    --swatch-border-mocha-brown: solid;
    --swatch-color-irish-cream: #F3E5AB;
    --swatch-border-irish-cream: solid;
    --swatch-color-mist-grey: #B0B7BD;
    --swatch-border-mist-grey: solid;
    --swatch-color-luna-grey: #8E8E93;
    --swatch-border-luna-grey: solid;

    {%- for block in section.blocks -%}
      {%- if block.type == 'color_swatch' -%}
        {%- assign swatch_key = block.settings.color_name | downcase | strip | replace: ' ', '-' -%}
        {%- if swatch_key != blank and block.settings.hex_code != blank -%}
          --swatch-color-{{ swatch_key }}: {{ block.settings.hex_code }};
          --swatch-border-{{ swatch_key }}: solid;
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Color Swatches",
  "limit": 1,
  "settings": [],
  "blocks": [
    {
      "type": "color_swatch",
      "name": "Color Swatch",
      "settings": [
        {
          "type": "text",
          "id": "color_name",
          "label": "Color Name",
          "info": "Must match the variant color option value (e.g. Orchid Purple)"
        },
        {
          "type": "color",
          "id": "hex_code",
          "label": "Hex Code"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Color Swatches",
      "blocks": [
        { "type": "color_swatch", "settings": { "color_name": "Jet Black", "hex_code": "#0A0A0A" } },
        { "type": "color_swatch", "settings": { "color_name": "Pure White", "hex_code": "#FFFFFF" } },
