<section
  class="collection-carousel-pro"
  id="collection-carousel-{{ section.id }}"
>

  <div class="collection-carousel-pro__container">

    <div class="collection-carousel-pro__content">

      {% if section.settings.small_heading != blank %}
        <div class="collection-carousel-pro__eyebrow">
          {{ section.settings.small_heading }}
        </div>
      {% endif %}

      {% if section.settings.main_heading != blank %}
        <h2 class="collection-carousel-pro__heading">
          {{ section.settings.main_heading }}
        </h2>
      {% endif %}

      {% if section.settings.description != blank %}
        <div class="collection-carousel-pro__description">
          {{ section.settings.description }}
        </div>
      {% endif %}

      {% if section.settings.enable_shop_all_button %}
        <a
          href="{% if section.settings.shop_all_button_link != blank %}{{ section.settings.shop_all_button_link }}{% else %}#{% endif %}"
          class="collection-carousel-pro__shop-all-btn best-seller-shop-all-btn"
        >
          {{ section.settings.shop_all_button_text }}
        </a>
      {% endif %}

    </div>

    <div class="collection-carousel-pro__slider-wrapper">

      <div class="splide collection-carousel-splide">

        <div class="splide__track">

          <ul class="splide__list">

            {% for block in section.blocks %}

              <li
                class="splide__slide"
                {{ block.shopify_attributes }}
              >

                <a
                  href="{% if block.settings.link != blank %}{{ block.settings.link }}{% else %}#{% endif %}"
                  class="collection-carousel-pro__card"
                >

                  {% if block.settings.image != blank %}
                    {{
                      block.settings.image
                      | image_url: width: 1200
                      | image_tag:
                        loading: 'lazy',
                        class: 'collection-carousel-pro__image'
                    }}
                  {% endif %}

                  <div class="collection-carousel-pro__overlay"></div>

                  {% if block.settings.title != blank %}
                    <div class="collection-carousel-pro__title">
                      {{ block.settings.title }}
                    </div>
                  {% endif %}

                </a>

              </li>

            {% endfor %}

          </ul>

        </div>

      </div>

    </div>

  </div>

</section>

{%  style %}
.collection-carousel-pro {
  background: {{ section.settings.background_color }};
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
  overflow: hidden;
}

.collection-carousel-pro__container {
  max-width: 1800px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  gap: {{ section.settings.card_gap }}px;
}

.collection-carousel-pro__content {
  width: {{ section.settings.content_width }}%;
  flex-shrink: 0;
  padding-left: 60px;
}

.collection-carousel-pro__eyebrow {
  color: {{ section.settings.small_heading_color }};
  font-family: {{ section.settings.section_font.family }}, {{ section.settings.section_font.fallback_families }};
  font-size: {{ section.settings.small_heading_size }}px;
  font-weight: {{ section.settings.small_heading_weight }};
  text-transform: uppercase;
  margin-bottom: 20px;
}

.collection-carousel-pro__heading {
  color: {{ section.settings.main_heading_color }};
  font-family: {{ section.settings.section_font.family }}, {{ section.settings.section_font.fallback_families }};
  font-size: {{ section.settings.main_heading_size }}px;
  font-weight: {{ section.settings.main_heading_weight }};
  line-height: 1;
  text-transform: uppercase;
  margin: 0 0 24px;
}

.collection-carousel-pro__description {
  color: {{ section.settings.description_color }};
  font-family: {{ section.settings.section_font.family }}, {{ section.settings.section_font.fallback_families }};
  font-size: {{ section.settings.description_size }}px;
  font-weight: {{ section.settings.description_weight }};
  line-height: 1.7;
  max-width: 450px;
}

.collection-carousel-pro__shop-all-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  position: relative;
  width: {{ section.settings.shop_all_button_width_desktop }}px;
  max-width: 100%;
  height: {{ section.settings.shop_all_button_height_desktop }}px;
  margin-top: {{ section.settings.shop_all_button_margin_top }}px;
  margin-bottom: {{ section.settings.shop_all_button_margin_bottom }}px;
  padding: 0 16px;
  border: {{ section.settings.shop_all_button_border_width }}px solid {{ section.settings.shop_all_button_border_color }};
  border-radius: {{ section.settings.shop_all_button_border_radius }}px;
  background: {{ section.settings.shop_all_button_background_color }};
  color: {{ section.settings.shop_all_button_text_color }};
  font-family: {{ section.settings.section_font.family }}, {{ section.settings.section_font.fallback_families }};
  font-size: {{ section.settings.shop_all_button_font_size_desktop }}px;
  font-weight: {{ section.settings.shop_all_button_font_weight }};
  line-height: 1;
  text-transform: uppercase;
  text-decoration: none;
  text-align: center;
  box-sizing: border-box;
  overflow: hidden;
  isolation: isolate;
  transition: color .3s ease, border-color .3s ease, transform .3s ease, opacity .3s ease;
}

.collection-carousel-pro__shop-all-btn::before {
  content: '';
  position: absolute;
  inset: 0;
  z-index: -1;
  background: {{ section.settings.shop_all_button_border_color }};
}

.collection-carousel-pro__shop-all-btn:hover {
  color: #FFFFFF;
  background: #0c4168;
}


.collection-carousel-pro__slider-wrapper {
  flex: 1;
  min-width: 0;
}

.collection-carousel-splide {
  width: 100%;
}

.collection-carousel-pro__card {
  position: relative;
  display: block;
  height: {{ section.settings.card_height_desktop }}px;
  border-radius: {{ section.settings.card_radius }}px;
  overflow: hidden;
  text-decoration: none;
  -webkit-tap-highlight-color: transparent;
}

.collection-carousel-pro__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  pointer-events: none;
  transition: transform .4s ease;
}

.collection-carousel-pro__card:hover .collection-carousel-pro__image {
  transform: scale(1.05);
}

.collection-carousel-pro__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to top,
    {{ section.settings.overlay_color }} 0%,
    rgba(12,65,104,.65) 25%,
    transparent 65%
  );
  z-index: 1;
  pointer-events: none;
}

.collection-carousel-pro__title {
  position: absolute;
  left: 24px;
  bottom: 24px;
  z-index: 2;

  color: {{ section.settings.card_title_color }};
  font-family: {{ section.settings.section_font.family }}, {{ section.settings.section_font.fallback_families }};
  font-size: {{ section.settings.card_title_size }}px;
  font-weight: {{ section.settings.card_title_weight }};
  text-transform: uppercase;
  line-height: 1.1;
}

.collection-carousel-splide .splide__arrow {
  background: {{ section.settings.arrow_bg }};
  width: {{ section.settings.arrow_size }}px;
  height: {{ section.settings.arrow_size }}px;
  opacity: 1;
}

.collection-carousel-splide .splide__arrow svg {
  fill: {{ section.settings.arrow_color }};
}

.collection-carousel-splide .splide__pagination {
  display: none;
}

/* IMPORTANT FOR MOBILE SWIPE */

.collection-carousel-splide,
.collection-carousel-splide .splide__track,
.collection-carousel-splide .splide__list,
.collection-carousel-splide .splide__slide {
  touch-action: pan-y;
}

.collection-carousel-pro__card,
.collection-carousel-pro__image {
  user-select: none;
  -webkit-user-select: none;
  -webkit-user-drag: none;
}

/* MOBILE */

@media screen and (max-width: 767px) {

  .collection-carousel-pro {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  .collection-carousel-pro__container {
    flex-direction: column;
    gap: {{ section.settings.card_gap }}px;
  }

  .collection-carousel-pro__content {
    width: 100%;
    padding: 0 20px;
    text-align: center;
  }

  .collection-carousel-pro__description {
    max-width: 100%;
    margin: 0 auto;
    font-size: {{ section.settings.description_size_mobile }}px;
  }

  .collection-carousel-pro__shop-all-btn {
    width: {{ section.settings.shop_all_button_width_mobile }}px;
    height: {{ section.settings.shop_all_button_height_mobile }}px;
    font-size: {{ section.settings.shop_all_button_font_size_mobile }}px;
    margin-left: auto;
    margin-right: auto;
  }

  .collection-carousel-pro__eyebrow {
    font-size: {{ section.settings.small_heading_size_mobile }}px;
  }

  .collection-carousel-pro__heading {
    font-size: {{ section.settings.main_heading_size_mobile }}px;
    margin-bottom: 16px;
  }

  .collection-carousel-pro__slider-wrapper {
    width: 100%;
    padding-left: 20px;
  }

  .collection-carousel-pro__card {
    height: {{ section.settings.card_height_mobile }}px;
  }

  .collection-carousel-pro__title {
    left: 20px;
    bottom: 20px;
  }
}
{% endstyle %} 

<script>
document.addEventListener('DOMContentLoaded', function () {

  const section = document.getElementById('collection-carousel-{{ section.id }}');
  if (!section) return;

  const splideElement = section.querySelector('.collection-carousel-splide');
  if (!splideElement) return;

  if (typeof Splide === 'undefined') {
    console.error('Splide is not loaded');
    return;
  }

  const splide = new Splide(splideElement, {
    type: 'loop',

    perPage: 2,
    perMove: 1,

    gap: '{{ section.settings.card_gap }}px',

    arrows: true,
    pagination: false,

    drag: true,
    swipe: true,

    speed: 600,

    autoplay: true,
    interval: 2000,

    pauseOnHover: true,
    pauseOnFocus: true,

    resetProgress: false,

    breakpoints: {
      991: {
        perPage: 1.5,
      },

      767: {
        perPage: 1.1,
        gap: '{{ section.settings.card_gap }}px',

        drag: true,
        swipe: true,

        arrows: true,
        pagination: false,
      }
    }
  });

  splide.mount();

});
</script>

