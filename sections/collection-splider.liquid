{% comment %}
  Featured Collection Slider Section
  - Fetches products from a selected collection
  - Horizontal scroll with prev/next arrows
  - "Shop All" / "View All" button
  - Matches Kith-style minimal editorial product display
{% endcomment %}

<section class="fcs-section" id="fcs-{{ section.id }}">
  <div class="fcs-wrapper">

    {% if section.settings.heading != blank %}
      <h2 class="fcs-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="fcs-slider-outer">
      <button class="fcs-arrow fcs-arrow--prev" aria-label="Previous">
        <svg width="10" height="18" viewBox="0 0 10 18" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M9 1L1 9L9 17" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <div class="fcs-track-container">
        <div class="fcs-track" id="fcs-track-{{ section.id }}">
          {% assign collection = collections[section.settings.collection] %}
          {% if collection != blank %}
            {% for product in collection.products limit: section.settings.products_to_show %}
              <div class="fcs-card">
                <a href="{{ product.url }}" class="fcs-card-link">
                  <div class="fcs-card-image-wrap">
                    {% if product.featured_image != blank %}
                      <img
                        src="{{ product.featured_image | image_url: width: 600 }}"
                        alt="{{ product.featured_image.alt | escape | default: product.title }}"
                        class="fcs-card-img"
                        loading="lazy"
                        width="600"
                        height="700"
                      >
                    {% else %}
                      {{ 'product-1' | placeholder_svg_tag: 'fcs-placeholder-svg' }}
                    {% endif %}
                  </div>
                  <div class="fcs-card-info">
                    <p class="fcs-card-title">{{ product.title }}</p>
                    <p class="fcs-card-price">
                      {% if product.compare_at_price > product.price %}
                        <s class="fcs-price-compare">{{ product.compare_at_price | money_without_trailing_zeros }} INR</s>
                      {% endif %}
                      {{ product.price | money_without_trailing_zeros }} INR
                    </p>
                  </div>
                </a>
              </div>
            {% endfor %}
          {% else %}
            {% for i in (1..5) %}
              <div class="fcs-card">
                <div class="fcs-card-link">
                  <div class="fcs-card-image-wrap">
                    {{ 'product-' | append: i | placeholder_svg_tag: 'fcs-placeholder-svg' }}
                  </div>
                  <div class="fcs-card-info">
                    <p class="fcs-card-title">Sample Product {{ i }}</p>
                    <p class="fcs-card-price">Rs. 0.00 INR</p>
                  </div>
                </div>
              </div>
            {% endfor %}
          {% endif %}
        </div>
      </div>

      <button class="fcs-arrow fcs-arrow--next" aria-label="Next">
        <svg width="10" height="18" viewBox="0 0 10 18" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M1 1L9 9L1 17" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>

    {% if section.settings.show_view_all %}
      <div class="fcs-view-all-wrap">
        <a
          href="{% if collection != blank %}{{ collection.url }}{% else %}/collections/all{% endif %}"
          class="fcs-view-all-btn"
        >
          {{ section.settings.button_label | default: 'SHOP ALL' }}
        </a>
      </div>
    {% endif %}

  </div>
</section>

<style>
.fcs-card-title {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;

  line-height: 1.5;

  font-family: var(--wb-font-body);
  font-size: var(--wb-body);
  font-weight: var(--wb-fw-bold);
  color: var(--wb-color-blue);

  margin: 0 0 6px;
}

#fcs-{{ section.id }} {
  --fcs-bg: var(--wb-color-white);
  --fcs-text: var(--wb-color-blue);
  --fcs-muted: var(--wb-color-grey);

  --fcs-title-size: var(--wb-body);
  --fcs-price-size: var(--wb-body-sm);

  --fcs-title-weight: var(--wb-fw-bold);

  --fcs-font: var(--wb-font-body);

  --fcs-card-gap: 16px;
  --fcs-arrow-size: 40px;
  --fcs-card-width: 240px;

  background: var(--fcs-bg);
  padding: {{ section.settings.section_padding_top }}px 0 {{ section.settings.section_padding_bottom }}px;
}

.fcs-wrapper {
  max-width: 94%;
  margin: 0 auto;
}

/* Heading */
.fcs-heading {
  font-family: var(--wb-font-heading);
  font-size: var(--wb-h3);
  font-weight: var(--wb-fw-extrabold);
  color: var(--wb-color-blue);
  text-transform: uppercase;
  letter-spacing: var(--wb-letter-tight);
  line-height: var(--wb-line-tight);
  margin-bottom: 24px;
}

/* Outer slider layout */
.fcs-slider-outer {
  position: relative;
  display: flex;
  align-items: center;
  gap: 0;
}

/* Arrow Buttons */
.fcs-arrow {
  flex-shrink: 0;
  width: var(--fcs-arrow-size);
  height: var(--fcs-arrow-size);
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  border: none;
  cursor: pointer;
  color: var(--wb-color-blue);
  padding: 0;
  position: absolute;
  top: 40%;
  transform: translateY(-50%);
  z-index: 10;
  transition: var(--wb-transition);
}

.fcs-arrow:hover {
  opacity: 1;
}

.fcs-arrow--prev {
  left: -44px;
}

.fcs-arrow--next {
  right: -44px;
}

.fcs-arrow.fcs-arrow--hidden {
  opacity: 0;
  pointer-events: none;
}

/* Track container */
.fcs-track-container {
  overflow: hidden;
  width: 100%;
}

/* Track */
.fcs-track {
  display: flex;
  gap: var(--fcs-card-gap);
  transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  will-change: transform;
}

/* Card */
.fcs-card {
  flex: 0 0 var(--fcs-card-width);
  width: var(--fcs-card-width);
  transition: transform 0.3s ease;
}

.fcs-card:hover {
  transform: translateY(-4px);
}

.fcs-card-link {
  display: block;
  text-decoration: none;
  color: inherit;
}

/* Image */
.fcs-card-image-wrap {
  width: 100%;
  aspect-ratio: 3 / 3.6;
  background: #f7f7f7;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.fcs-card-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.4s ease;
}

.fcs-card-link:hover .fcs-card-img {
  transform: scale(1.04);
}

.fcs-placeholder-svg {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* Card Info */
.fcs-card-info {
  margin-top: 12px;
}

/* Product Title */
.fcs-card-title {
  font-family: var(--wb-font-body);
  font-size: var(--fcs-title-size);
  font-weight: var(--fcs-title-weight);
  color: var(--wb-color-blue);
  line-height: 1.5;
  letter-spacing: 0;
  margin: 0 0 6px;
}

/* Price */
.fcs-card-price {
  font-family: var(--wb-font-body);
  font-size: var(--fcs-price-size);
  font-weight: var(--wb-fw-medium);
  color: var(--wb-color-grey);
  margin: 0;
}

/* Compare Price */
.fcs-price-compare {
  color: var(--wb-color-grey);
  opacity: 0.7;
  margin-right: 6px;
}

/* View All Button */
.fcs-view-all-wrap {
  display: flex;
  justify-content: center;
  margin-top: 36px;
}

.fcs-view-all-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;

  min-height: var(--wb-btn-height);

  padding:
    var(--wb-btn-padding-y)
    var(--wb-btn-padding-x);

  color: var(--wb-color-blue);

  border: 2px solid var(--wb-color-blue);

  font-family: var(--wb-font-heading);
  font-size: 14px;
  font-weight: var(--wb-btn-font-weight);

  letter-spacing: var(--wb-btn-letter-spacing);
  text-transform: uppercase;

  text-decoration: none;

  transition: var(--wb-transition);

  border-radius: var(--wb-btn-radius);
}

.fcs-view-all-btn:hover {
  background: var(--wb-color-blue);
  color: var(--wb-color-white);
  transform: translateY(-2px);
}

/* Tablet */
@media (max-width: 1100px) {
  .fcs-arrow--prev {
    left: -10px;
  }

  .fcs-arrow--next {
    right: -10px;
  }

  #fcs-{{ section.id }} {
    --fcs-card-width: 210px;
  }
}

/* Mobile */
@media (max-width: 768px) {
  #fcs-{{ section.id }} {
    --fcs-card-width: 180px;
    --fcs-card-gap: 12px;
  }
  .fcs-section{
    padding-top: 24px !important;
    padding-bottom: 24px !important;
  }

  .fcs-heading {
    font-size: clamp(28px, 7vw, 36px);
    text-align: center;
  }

  .fcs-arrow--prev {
    left: 0;
  }

  .fcs-arrow--next {
    right: 0;
  }

  .fcs-card-title {
    font-size: 14px;
    line-height: 1.4;
  }

  .fcs-card-price {
    font-size: 15px;
    color: rgb(68, 68, 68)
  }

  .fcs-view-all-btn {
    width: 100%;
    max-width: 144px;
    font-size: 10px;
    padding: 10px;
    min-height: 40px;
  }
}

/* Small Mobile */
@media (max-width: 480px) {
  #fcs-{{ section.id }} {
    --fcs-card-width: 150px;
  }

  .fcs-card-title {
    font-size: 13px;
  }

  .fcs-card-price {
    font-size: 12px;
  }
}
</style>

<script>
  (function () {
    var sectionId = {{ section.id | json }};
    var track = document.getElementById('fcs-track-' + sectionId);
    var section = document.getElementById('fcs-' + sectionId);
    if (!track || !section) return;

    var prevBtn = section.querySelector('.fcs-arrow--prev');
    var nextBtn = section.querySelector('.fcs-arrow--next');

    var currentIndex = 0;

    function getVisibleCount() {
      var container = track.parentElement;
      var containerW = container.offsetWidth;
      var cardW = track.children[0] ? track.children[0].offsetWidth : 240;
      var gap = parseInt(getComputedStyle(track).gap) || 16;
      return Math.floor((containerW + gap) / (cardW + gap));
    }

    function getTotalCards() {
      return track.children.length;
    }

    function getCardStep() {
      var card = track.children[0];
      if (!card) return 256;
      var gap = parseInt(getComputedStyle(track).gap) || 16;
      return card.offsetWidth + gap;
    }

    function clampIndex(idx) {
      var visible = getVisibleCount();
      var total = getTotalCards();
      var max = Math.max(0, total - visible);
      return Math.min(Math.max(idx, 0), max);
    }

    function updateSlider() {
      currentIndex = clampIndex(currentIndex);
      var step = getCardStep();
      track.style.transform = 'translateX(-' + (currentIndex * step) + 'px)';

      var visible = getVisibleCount();
      var total = getTotalCards();

      if (prevBtn) prevBtn.classList.toggle('fcs-arrow--hidden', currentIndex === 0);
      if (nextBtn) nextBtn.classList.toggle('fcs-arrow--hidden', currentIndex >= total - visible);
    }

    if (prevBtn) {
      prevBtn.addEventListener('click', function () {
        currentIndex -= 1;
        updateSlider();
      });
    }

    if (nextBtn) {
      nextBtn.addEventListener('click', function () {
        currentIndex += 1;
        updateSlider();
      });
    }

    // Init
    updateSlider();
    window.addEventListener('resize', function () {
      currentIndex = 0;
      updateSlider();
    });
  })();
</script>

{% schema %}
{
  "name": "Collection Slider",
  "tag": "section",
  "class": "fcs-section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 24,
      "step": 1,
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'Shop All' button",
      "default": true
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "SHOP ALL"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Collection Slider",
      "category": "Collection"
    }
  ]
}
{% endschema %}
