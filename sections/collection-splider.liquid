{% comment %}
  Featured Collection Slider Section
  - Fetches products from a selected collection
  - Horizontal scroll with prev/next arrows
  - "Shop All" / "View All" button
  - Matches Kith-style minimal editorial product display
{% endcomment %}

<section class="fcs-section" id="fcs-{{ section.id }}">
  <div class="fcs-wrapper">

    {% if section.settings.heading != blank %}
      <h2 class="fcs-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="fcs-slider-outer">
      <button class="fcs-arrow fcs-arrow--prev" aria-label="Previous">
        <svg width="10" height="18" viewBox="0 0 10 18" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M9 1L1 9L9 17" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <div class="fcs-track-container">
        <div class="fcs-track" id="fcs-track-{{ section.id }}">
          {% assign collection = collections[section.settings.collection] %}
          {% if collection != blank %}
            {% for product in collection.products limit: section.settings.products_to_show %}
              <div class="fcs-card">
                <a href="{{ product.url }}" class="fcs-card-link">
                  <div class="fcs-card-image-wrap">
                    {% if product.featured_image != blank %}
                      <img
                        src="{{ product.featured_image | image_url: width: 600 }}"
                        alt="{{ product.featured_image.alt | escape | default: product.title }}"
                        class="fcs-card-img"
                        loading="lazy"
                        width="600"
                        height="700"
                      >
                    {% else %}
                      {{ 'product-1' | placeholder_svg_tag: 'fcs-placeholder-svg' }}
                    {% endif %}
                  </div>
                  <div class="fcs-card-info">
                    <p class="fcs-card-title">{{ product.title }}</p>
                    <p class="fcs-card-price">
                      {% if product.compare_at_price > product.price %}
                        <s class="fcs-price-compare">{{ product.compare_at_price | money_without_trailing_zeros }} INR</s>
                      {% endif %}
                      {{ product.price | money_without_trailing_zeros }} INR
                    </p>
                  </div>
                </a>
              </div>
            {% endfor %}
          {% else %}
            {% for i in (1..5) %}
              <div class="fcs-card">
                <div class="fcs-card-link">
                  <div class="fcs-card-image-wrap">
                    {{ 'product-' | append: i | placeholder_svg_tag: 'fcs-placeholder-svg' }}
                  </div>
                  <div class="fcs-card-info">
                    <p class="fcs-card-title">Sample Product {{ i }}</p>
                    <p class="fcs-card-price">Rs. 0.00 INR</p>
                  </div>
                </div>
              </div>
            {% endfor %}
          {% endif %}
        </div>
      </div>

      <button class="fcs-arrow fcs-arrow--next" aria-label="Next">
        <svg width="10" height="18" viewBox="0 0 10 18" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M1 1L9 9L1 17" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>

    {% if section.settings.show_view_all %}
      <div class="fcs-view-all-wrap">
        <a
          href="{% if collection != blank %}{{ collection.url }}{% else %}/collections/all{% endif %}"
          class="fcs-view-all-btn"
        >
          {{ section.settings.button_label | default: 'SHOP ALL' }}
        </a>
      </div>
    {% endif %}


  </div>
</section>

<style>
  .fcs-track-container {
  overflow-x: auto;
  scroll-behavior: smooth;
  -webkit-overflow-scrolling: touch;
}
.fcs-card-title {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.5;
  font-size: var(--fcs-title-size);
  font-weight: var(--fcs-title-weight);
  color: var(--fcs-title-color);
  margin: 0 0 6px;
}

#fcs-{{ section.id }} {
  --fcs-bg: {{ section.settings.section_bg_color }};
  --fcs-text: {{ section.settings.heading_color }};
  --fcs-muted: {{ section.settings.price_color }};
  --fcs-title-color: {{ section.settings.title_color }};
  --fcs-compare-color: {{ section.settings.compare_price_color }};
  --fcs-card-bg: {{ section.settings.card_bg_color }};
  --fcs-image-bg: {{ section.settings.image_bg_color }};

  --fcs-title-size: {{ section.settings.title_size_desktop }}px;
  --fcs-title-size-mobile: {{ section.settings.title_size_mobile }}px;
  --fcs-price-size: {{ section.settings.price_size_desktop }}px;
  --fcs-price-size-mobile: {{ section.settings.price_size_mobile }}px;

  --fcs-title-weight: {{ section.settings.title_weight }};
  --fcs-price-weight: {{ section.settings.price_weight }};
  --fcs-heading-size: {{ section.settings.heading_size_desktop }}px;
  --fcs-heading-size-mobile: {{ section.settings.heading_size_mobile }}px;
  --fcs-heading-weight: {{ section.settings.heading_weight }};
  --fcs-heading-align: {{ section.settings.heading_alignment }};
  --fcs-heading-mb: {{ section.settings.heading_margin_bottom }}px;

  --fcs-font: var(--wb-font-body);

  --fcs-card-gap: {{ section.settings.card_gap_desktop }}px;
  --fcs-card-gap-mobile: {{ section.settings.card_gap_mobile }}px;
  --fcs-arrow-size: {{ section.settings.arrow_size_desktop }}px;
  --fcs-arrow-size-mobile: {{ section.settings.arrow_size_mobile }}px;
  --fcs-card-width: {{ section.settings.card_width_desktop }}px;
  --fcs-card-width-tablet: {{ section.settings.card_width_tablet }}px;
  --fcs-card-width-mobile: {{ section.settings.card_width_mobile }}px;
  --fcs-arrow-offset: {{ section.settings.arrow_offset_desktop }}px;
  --fcs-arrow-offset-tablet: {{ section.settings.arrow_offset_tablet }}px;
  --fcs-arrow-color: {{ section.settings.arrow_color }};
  --fcs-arrow-bg: {{ section.settings.arrow_bg_color }};
  --fcs-arrow-radius: {{ section.settings.arrow_border_radius }}px;

  --fcs-image-ratio: {{ section.settings.image_ratio_desktop }};
  --fcs-image-ratio-mobile: {{ section.settings.image_ratio_mobile }};
  --fcs-card-info-mt: {{ section.settings.card_info_spacing }}px;
  --fcs-view-all-mt: {{ section.settings.button_margin_top }}px;

  --fcs-btn-width: {{ section.settings.button_width_desktop }}px;
  --fcs-btn-height: {{ section.settings.button_height_desktop }}px;
  --fcs-btn-width-mobile: {{ section.settings.button_width_mobile }}px;
  --fcs-btn-height-mobile: {{ section.settings.button_height_mobile }}px;
  --fcs-btn-font-size: {{ section.settings.button_font_size_desktop }}px;
  --fcs-btn-font-size-mobile: {{ section.settings.button_font_size_mobile }}px;
  --fcs-btn-font-weight: {{ section.settings.button_font_weight }};
  --fcs-btn-text: {{ section.settings.button_text_color }};
  --fcs-btn-bg: {{ section.settings.button_bg_color }};
  --fcs-btn-border-color: {{ section.settings.button_border_color }};
  --fcs-btn-border-width: {{ section.settings.button_border_width }}px;
  --fcs-btn-radius: {{ section.settings.button_border_radius }}px;
  --fcs-btn-padding-x: {{ section.settings.button_padding_x }}px;
  --fcs-btn-padding-y: {{ section.settings.button_padding_y }}px;
  --fcs-btn-padding-x-mobile: {{ section.settings.button_padding_x_mobile }}px;
  --fcs-btn-padding-y-mobile: {{ section.settings.button_padding_y_mobile }}px;
  --fcs-btn-hover-bg: {{ section.settings.button_hover_bg_color }};
  --fcs-btn-hover-text: {{ section.settings.button_hover_text_color }};
  --fcs-btn-hover-border: {{ section.settings.button_hover_border_color }};

  background: var(--fcs-bg);
  padding: {{ section.settings.section_padding_top }}px 0 {{ section.settings.section_padding_bottom }}px;
}

.fcs-wrapper {
  max-width: {{ section.settings.wrapper_width }}%;
  margin: 0 auto;
}

/* Heading */
.fcs-heading {
  font-family: var(--wb-font-heading);
  font-size: var(--fcs-heading-size);
  font-weight: var(--fcs-heading-weight);
  color: var(--fcs-text);
  text-transform: uppercase;
  letter-spacing: var(--wb-letter-tight);
  line-height: var(--wb-line-tight);
  margin-bottom: var(--fcs-heading-mb);
  text-align: var(--fcs-heading-align);
}

/* Outer slider layout */
.fcs-slider-outer {
  position: relative;
  display: flex;
  align-items: center;
  gap: 0;
}

/* Arrow Buttons */
.fcs-arrow {
  flex-shrink: 0;
  width: var(--fcs-arrow-size);
  height: var(--fcs-arrow-size);
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--fcs-arrow-bg);
  border: none;
  cursor: pointer;
  color: var(--fcs-arrow-color);
  padding: 0;
  position: absolute;
  top: 40%;
  transform: translateY(-50%);
  z-index: 10;
  transition: var(--wb-transition);
  border-radius: var(--fcs-arrow-radius);
}

.fcs-arrow:hover {
  opacity: 1;
}

.fcs-arrow--prev {
  left: calc(var(--fcs-arrow-offset) * -1);
}

.fcs-arrow--next {
  right: calc(var(--fcs-arrow-offset) * -1);
}

.fcs-arrow.fcs-arrow--hidden {
  opacity: 0;
  pointer-events: none;
}

/* Track container */
.fcs-track-container {
  overflow: hidden;
  width: 100%;
}

/* Track */
.fcs-track {
  display: flex;
  gap: var(--fcs-card-gap);
  transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  will-change: transform;
}

/* Card */
.fcs-card {
  flex: 0 0 var(--fcs-card-width);
  width: var(--fcs-card-width);
  transition: transform 0.3s ease;
  background: var(--fcs-card-bg);
}

.fcs-card:hover {
  transform: translateY(-4px);
}

.fcs-card-link {
  display: block;
  text-decoration: none;
  color: inherit;
}

/* Image */
.fcs-card-image-wrap {
  width: 100%;
  aspect-ratio: var(--fcs-image-ratio);
  background: var(--fcs-image-bg);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.fcs-card-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.4s ease;
}

.fcs-card-link:hover .fcs-card-img {
  transform: scale(1.04);
}

.fcs-placeholder-svg {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* Card Info */
.fcs-card-info {
  margin-top: var(--fcs-card-info-mt);
}

/* Product Title */
.fcs-card-title {
  font-family: Helvetica;
  font-size: var(--fcs-title-size);
  font-weight: var(--fcs-title-weight);
  color: var(--fcs-title-color);
  line-height: 1.5;
  letter-spacing: 0;
  margin: 0 0 6px;
}

/* Price */
.fcs-card-price {
  font-size: var(--fcs-price-size);
  font-weight: var(--fcs-price-weight);
  color: var(--fcs-muted);
  margin: 0;
  font-weight: 700;
}

/* Compare Price */
.fcs-price-compare {
  color: var(--fcs-compare-color);
  opacity: 0.7;
  margin-right: 6px;
}

/* View All Button */
.fcs-view-all-wrap {
  display: flex;
  justify-content: center;
  margin-top: var(--fcs-view-all-mt);
}

.fcs-view-all-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: var(--fcs-btn-width);
  min-width: var(--fcs-btn-width);
  height: var(--fcs-btn-height);
  min-height: var(--fcs-btn-height);
  padding: var(--fcs-btn-padding-y) var(--fcs-btn-padding-x);
  color: var(--fcs-btn-text);
  background: var(--fcs-btn-bg);
  border: var(--fcs-btn-border-width) solid var(--fcs-btn-border-color);
  font-family: var(--wb-font-heading);
  font-size: var(--fcs-btn-font-size);
  font-weight: var(--fcs-btn-font-weight);
  letter-spacing: var(--wb-btn-letter-spacing);
  text-transform: uppercase;
  text-decoration: none;
  transition: var(--wb-transition);
  border-radius: var(--fcs-btn-radius);
  box-sizing: border-box;
}

.fcs-view-all-btn:hover {
  background: var(--fcs-btn-hover-bg);
  color: var(--fcs-btn-hover-text);
  border-color: var(--fcs-btn-hover-border);
  transform: translateY(-2px);
}

/* Tablet */
@media (max-width: 1100px) {
  .fcs-arrow--prev {
    left: calc(var(--fcs-arrow-offset-tablet) * -1);
  }

  .fcs-arrow--next {
    right: calc(var(--fcs-arrow-offset-tablet) * -1);
  }

  #fcs-{{ section.id }} {
    --fcs-card-width: var(--fcs-card-width-tablet);
  }
}

/* Mobile */
@media (max-width: 768px) {
  #fcs-{{ section.id }} {
    --fcs-card-width: var(--fcs-card-width-mobile);
    --fcs-card-gap: var(--fcs-card-gap-mobile);
    --fcs-image-ratio: var(--fcs-image-ratio-mobile);
    --fcs-arrow-size: var(--fcs-arrow-size-mobile);
  }
  .fcs-section{
    padding-top: {{ section.settings.section_padding_top_mobile }}px !important;
    padding-bottom: {{ section.settings.section_padding_bottom_mobile }}px !important;
  }

  .fcs-heading {
    font-size: var(--fcs-heading-size-mobile);
    text-align: {{ section.settings.heading_alignment_mobile }};
  }

  .fcs-arrow--prev {
    left: 0;
  }

  .fcs-arrow--next {
    right: 0;
  }

  .fcs-card-title {
    font-size: var(--fcs-title-size-mobile);
    line-height: 1.4;
  }
.timeline-tabs{
  padding-top: 0px !important;
  padding-bottom: 30px !important;
}
  .fcs-card-price {
    font-size: var(--fcs-price-size-mobile);
    color: var(--fcs-muted);
  }

  .fcs-view-all-btn {
    width: var(--fcs-btn-width-mobile);
    min-width: var(--fcs-btn-width-mobile);
    max-width: 100%;
    height: var(--fcs-btn-height-mobile);
    min-height: var(--fcs-btn-height-mobile);
    font-size: var(--fcs-btn-font-size-mobile);
    padding: var(--fcs-btn-padding-y-mobile) var(--fcs-btn-padding-x-mobile);
  }
}

/* Small Mobile */
@media (max-width: 480px) {
  #fcs-{{ section.id }} {
    --fcs-card-width: var(--fcs-card-width-mobile);
    --fcs-image-ratio: var(--fcs-image-ratio-mobile);
  }
}
</style>

<script>
(function () {
  var sectionId = {{ section.id | json }};
  var track = document.getElementById('fcs-track-' + sectionId);
  var section = document.getElementById('fcs-' + sectionId);

  if (!track || !section) return;

  var prevBtn = section.querySelector('.fcs-arrow--prev');
  var nextBtn = section.querySelector('.fcs-arrow--next');
  var container = track.parentElement;

  var currentIndex = 0;

  function getVisibleCount() {
    var containerW = container.offsetWidth;
    var cardW = track.children[0] ? track.children[0].offsetWidth : 240;
    var gap = parseInt(getComputedStyle(track).gap) || 16;

    return Math.floor((containerW + gap) / (cardW + gap));
  }

  function getTotalCards() {
    return track.children.length;
  }

  function getCardStep() {
    var card = track.children[0];

    if (!card) return 256;

    var gap = parseInt(getComputedStyle(track).gap) || 16;

    return card.offsetWidth + gap;
  }

  function clampIndex(idx) {
    var visible = getVisibleCount();
    var total = getTotalCards();
    var max = Math.max(0, total - visible);

    return Math.min(Math.max(idx, 0), max);
  }

  function updateSlider() {
    currentIndex = clampIndex(currentIndex);

    var step = getCardStep();

    track.style.transform =
      'translateX(-' + currentIndex * step + 'px)';

    var visible = getVisibleCount();
    var total = getTotalCards();

    if (prevBtn) {
      prevBtn.classList.toggle(
        'fcs-arrow--hidden',
        currentIndex === 0
      );
    }

    if (nextBtn) {
      nextBtn.classList.toggle(
        'fcs-arrow--hidden',
        currentIndex >= total - visible
      );
    }
  }

  // Arrow Navigation
  if (prevBtn) {
    prevBtn.addEventListener('click', function () {
      currentIndex--;
      updateSlider();
    });
  }

  if (nextBtn) {
    nextBtn.addEventListener('click', function () {
      currentIndex++;
      updateSlider();
    });
  }

  // ======================
  // Mouse Drag Support
  // ======================

  let isDragging = false;
  let startX = 0;
  let dragStartIndex = 0;

  container.addEventListener('mousedown', function (e) {
    isDragging = true;
    startX = e.pageX;
    dragStartIndex = currentIndex;

    container.style.cursor = 'grabbing';
  });

  document.addEventListener('mouseup', function () {
    isDragging = false;
    container.style.cursor = 'grab';
  });

  document.addEventListener('mousemove', function (e) {
    if (!isDragging) return;

    const diff = e.pageX - startX;
    const step = getCardStep();

    if (Math.abs(diff) > step / 3) {
      if (diff > 0) {
        currentIndex = dragStartIndex - 1;
      } else {
        currentIndex = dragStartIndex + 1;
      }

      updateSlider();
      isDragging = false;
    }
  });

  // ======================
  // Touch Swipe Support
  // ======================

  let touchStartX = 0;

  container.addEventListener(
    'touchstart',
    function (e) {
      touchStartX = e.touches[0].clientX;
    },
    { passive: true }
  );

  container.addEventListener(
    'touchend',
    function (e) {
      const touchEndX = e.changedTouches[0].clientX;
      const diff = touchStartX - touchEndX;

      if (Math.abs(diff) > 50) {
        if (diff > 0) {
          currentIndex++;
        } else {
          currentIndex--;
        }

        updateSlider();
      }
    },
    { passive: true }
  );

  // Init
  updateSlider();

  window.addEventListener('resize', function () {
    currentIndex = clampIndex(currentIndex);
    updateSlider();
  });
})();
</script>
{% schema %}
{
  "name": "Collection Slider",
  "tag": "section",
  "class": "fcs-section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 24,
      "step": 1,
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'Shop All' button",
      "default": true
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "SHOP ALL"
    },
    {
      "type": "header",
      "content": "Section Layout"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Section background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "wrapper_width",
      "label": "Content width",
      "min": 80,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 94
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Padding top desktop",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Padding bottom desktop",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "section_padding_top_mobile",
      "label": "Padding top mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 30,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "section_padding_bottom_mobile",
      "label": "Padding bottom mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 30,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#0c4168"
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "label": "Heading size desktop",
      "min": 16,
      "max": 80,
      "step": 1,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading size mobile",
      "min": 14,
      "max": 60,
      "step": 1,
      "default": 32,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading font weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi Bold" },
        { "value": "700", "label": "Bold" },
        { "value": "800", "label": "Extra Bold" },
        { "value": "900", "label": "Black" }
      ],
      "default": "800"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment desktop",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "heading_alignment_mobile",
      "label": "Heading alignment mobile",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "heading_margin_bottom",
      "label": "Heading bottom spacing",
      "min": 0,
      "max": 60,
      "step": 2,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Cards"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card background color",
      "default": "transparent"
    },
    {
      "type": "color",
      "id": "image_bg_color",
      "label": "Image background color",
      "default": "#f7f7f7"
    },
    {
      "type": "text",
